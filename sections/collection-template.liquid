  /* Canvas fallback for any name not in the map */
  var _canvas = document.createElement('canvas');
  _canvas.width = _canvas.height = 1;
  var _ctx = _canvas.getContext && _canvas.getContext('2d');

  function resolveColor(name) {
    var lower = (name || '').toLowerCase().trim();

    /* 1. Direct map lookup */
    if (COLOR_MAP[lower]) return COLOR_MAP[lower];

    /* 2. Partial match — "dark olive green" → try "dark olive", "olive green", "olive" */
    var parts = lower.split(/\s+/);
    for (var i = parts.length - 1; i >= 1; i--) {
      var sub = parts.slice(0, i).join(' ');
      if (COLOR_MAP[sub]) return COLOR_MAP[sub];
    }
    /* Last word only */
    if (parts.length > 1 && COLOR_MAP[parts[parts.length - 1]]) {
      return COLOR_MAP[parts[parts.length - 1]];
    }

    /* 3. Canvas CSS color parse */
    if (_ctx) {
      try {
        _ctx.clearRect(0, 0, 1, 1);
        _ctx.fillStyle = '#cccccc';
        _ctx.fillStyle = lower;
        _ctx.fillRect(0, 0, 1, 1);
        var d = _ctx.getImageData(0, 0, 1, 1).data;
        if (d[3] > 0) return 'rgb(' + d[0] + ',' + d[1] + ',' + d[2] + ')';
      } catch(e) {}
    }

    /* 4. Fallback */
    return '#cccccc';
  }

  function applySwatchColors() {
    document.querySelectorAll('[data-color-name]').forEach(function(el) {
      var color = resolveColor(el.getAttribute('data-color-name'));
      /* Gradient-like values can't go on background-color, use background */
      if (color.indexOf('gradient') !== -1 || color.indexOf('linear') !== -1) {
        el.style.background = color;
      } else {
        el.style.backgroundColor = color;
        /* Light colors need a visible border */
        if (color === '#ffffff' || color === '#fffff0' || color === '#faf7f2' ||
            color === '#fffdd0' || color === '#faf0e6' || color === '#f0ead6' ||
            color === '#fff8dc' || color === '#fdf5e6' || color === '#faebd7') {
          el.style.border = '2px solid #d1d5db';
        }
      }
    });
  }

  window.clApplyPrice = function (prefix) {
    var minEl = document.getElementById('cl-price-min-' + prefix);
    var maxEl = document.getElementById('cl-price-max-' + prefix);
    var url = new URL(window.location.href);
    if (minEl && minEl.value !== '') {
      url.searchParams.set('filter.v.price.gte', minEl.value);
    } else {
      url.searchParams.delete('filter.v.price.gte');
    }
    if (maxEl && maxEl.value !== '') {
      url.searchParams.set('filter.v.price.lte', maxEl.value);
    } else {
      url.searchParams.delete('filter.v.price.lte');
    }
    window.location.href = url.toString();
  };

  window.clSortChange = function (value) {
    var url = new URL(window.location.href);
    url.searchParams.set('sort_by', value);
    window.location.href = url.toString();
  };

  window.clOpenDrawer = function () {
    document.getElementById('cl-drawer').classList.add('open');
    document.getElementById('cl-overlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  };

  window.clCloseDrawer = function () {
    document.getElementById('cl-drawer').classList.remove('open');
    document.getElementById('cl-overlay').classList.remove('open');
    document.body.style.overflow = '';
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', applySwatchColors);
  } else {
    applySwatchColors();
  }
})();
</script>

