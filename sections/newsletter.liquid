{%- style -%}
 
  .newsletter-{{ section.id }} {
    --bg-color: {{ section.settings.color_scheme.settings.background }};
    --text-color: {{ section.settings.color_scheme.settings.text }};
    --btn-bg: {{ section.settings.color_scheme.settings.button }};
    --btn-text: {{ section.settings.color_scheme.settings.button_label }};
    
    background: var(--bg-color);
    {% if section.settings.color_scheme.settings.background_gradient != blank %}
      background: {{ section.settings.color_scheme.settings.background_gradient }};
    {% endif %}
    color: var(--text-color);
    text-align: {{ section.settings.text_alignment }};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mb }}px;
    padding-bottom: {{ section.settings.padding_bottom_mb }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .newsletter-container-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  
  .newsletter-{{ section.id }} .premium-input {
    background: transparent;
    color: var(--text-color);
    border: 1px solid rgba(0,0,0,0.1); 
  }

  .newsletter-{{ section.id }} .premium-submit-btn {
    background: var(--btn-bg);
    color: var(--btn-text);
  }

  .newsletter-{{ section.id }} .premium-input:focus ~ .premium-label,
  .newsletter-{{ section.id }} .premium-input:not(:placeholder-shown) ~ .premium-label {
    top: 10px !important;
    font-size: 11px !important;
    color: var(--text-color);
  }
{%- endstyle -%}

<section class="newsletter-{{ section.id }} section-{{ section.id }}-padding">
  <div class="newsletter-container-{{ section.id }}">
    <div class="newsletter-wrapper">
      {%- content_for 'blocks' -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Premium Newsletter",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 50,
      "default": 800,
      "label": "Section Max Width"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Color Customization"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mb",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Mobile Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mb",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Mobile Padding Bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    }
  ],

  "presets": [
    {
      "name": "Newsletter",
      "blocks": [
        { "type": "heading" },
        { "type": "subheading" },
        { "type": "newsletter_form" }
      ]
    }
  ]
}
{% endschema %}