{%- style -%}
  #shopify-section-{{ section.id }} .editorial-section {
    padding: {{ section.settings.padding_v }}px 0;
    background-color: {{ section.settings.color_scheme.settings.background }};
  }

  #shopify-section-{{ section.id }} .editorial-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    #shopify-section-{{ section.id }} .editorial-inner { padding: 0 1.5rem; }
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .editorial-inner { padding: 0 2rem; }
  }

  {% comment %} ── Section Header ── {% endcomment %}
  #shopify-section-{{ section.id }} .editorial-header {
    text-align: center;
    margin-bottom: 2.5rem;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  #shopify-section-{{ section.id }} .editorial-header.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  #shopify-section-{{ section.id }} .editorial-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    color: {{ section.settings.color_scheme.settings.text }};
    margin: 0 0 0.75rem 0;
  }
  #shopify-section-{{ section.id }} .editorial-subtitle {
    color: {{ section.settings.color_scheme.settings.secondary_button_label }};
    max-width: 40rem;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.6;
  }

  {% comment %} ── Grid Layout — 12 col: 1st card 9col×2row, 2nd & 3rd 3col×1row ── {% endcomment %}
  #shopify-section-{{ section.id }} .editorial-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .editorial-grid {
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: auto auto;
      gap: 1rem;
    }

    {% comment %} 1st card: 9 cols wide, spans both rows {% endcomment %}
    #shopify-section-{{ section.id }} .editorial-grid > *:nth-child(1) {
      grid-column: 1 / 10;
      grid-row: 1 / 3;
    }

    {% comment %} 2nd card: 3 cols wide, row 1 {% endcomment %}
    #shopify-section-{{ section.id }} .editorial-grid > *:nth-child(2) {
      grid-column: 10 / 13;
      grid-row: 1;
    }

    {% comment %} 3rd card: 3 cols wide, row 2 {% endcomment %}
    #shopify-section-{{ section.id }} .editorial-grid > *:nth-child(3) {
      grid-column: 10 / 13;
      grid-row: 2;
    }
  }
{%- endstyle -%}

<section class="editorial-section">
  <div class="editorial-inner">

    {% comment %} ── Section Header ── {% endcomment %}
    {% if section.settings.title != blank or section.settings.subtitle != blank %}
      <div class="editorial-header js-ed-reveal">
        {% if section.settings.title != blank %}
          <h2 class="editorial-title">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.subtitle != blank %}
          <p class="editorial-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% comment %} ── Grid — renders theme blocks ── {% endcomment %}
    <div class="editorial-grid">
      {% content_for 'blocks' %}
    </div>

  </div>
</section>

<script>
(function() {
  var items = document.querySelectorAll('#shopify-section-{{ section.id }} .js-ed-reveal');
  if (!items.length) return;
  if (!('IntersectionObserver' in window)) {
    items.forEach(function(el) { el.classList.add('is-visible'); });
    return;
  }
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        obs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });
  items.forEach(function(el) { obs.observe(el); });
})();
</script>

{% schema %}
{
  "name": "Editorial Grid",
  "blocks": [{ "type": "@theme" }, { "type": "@app" }],
  "settings": [
    {
      "type": "header",
      "content": "Color & Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_v",
      "label": "Padding Top / Bottom",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Shop the Edit"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    }
  ],
  "presets": [
    {
      "name": "Editorial Grid",
      "blocks": [
        {
          "type": "editorial-card",
          "settings": {
            "card_size": "large"
          }
        },
        {
          "type": "editorial-card",
          "settings": {
            "card_size": "small"
          }
        },
        {
          "type": "editorial-card",
          "settings": {
            "card_size": "small"
          }
        }
      ]
    }
  ]
}
{% endschema %}
