{% liquid
  comment
    ╔══════════════════════════════════════════════════════╗
    ║   HERO SECTION — Full Customizable                  ║
    ║   Supports: Dual Media, Mobile Media, Overlay,      ║
    ║   Blurred Reflection, Layout, Spacing,              ║
    ║   Hero Badge + Subheading + Heading + Button        ║
    ╚══════════════════════════════════════════════════════╝
  endcomment

  assign media_1 = 'none'
  assign media_2 = 'none'
  assign media_count = 0

  if section.settings.image_1 != blank and section.settings.media_type_1 == 'image'
    assign media_1 = 'image'
    assign media_count = media_count | plus: 1
  endif
  if section.settings.video_1 != blank and section.settings.media_type_1 == 'video'
    assign media_1 = 'video'
    assign media_count = media_count | plus: 1
  endif
  if section.settings.image_2 != blank and section.settings.media_type_2 == 'image'
    assign media_2 = 'image'
    assign media_count = media_count | plus: 1
  endif
  if section.settings.video_2 != blank and section.settings.media_type_2 == 'video'
    assign media_2 = 'video'
    assign media_count = media_count | plus: 1
  endif

  assign media_1_mob = 'none'
  assign media_2_mob = 'none'
  assign media_count_mob = 0

  if section.settings.custom_mobile_media
    if section.settings.image_1_mob != blank and section.settings.media_type_1_mob == 'image'
      assign media_1_mob = 'image'
      assign media_count_mob = media_count_mob | plus: 1
    endif
    if section.settings.video_1_mob != blank and section.settings.media_type_1_mob == 'video'
      assign media_1_mob = 'video'
      assign media_count_mob = media_count_mob | plus: 1
    endif
    if section.settings.image_2_mob != blank and section.settings.media_type_2_mob == 'image'
      assign media_2_mob = 'image'
      assign media_count_mob = media_count_mob | plus: 1
    endif
    if section.settings.video_2_mob != blank and section.settings.media_type_2_mob == 'video'
      assign media_2_mob = 'video'
      assign media_count_mob = media_count_mob | plus: 1
    endif
  endif

  if section.settings.custom_mobile_media == false or media_count_mob == 0
    assign media_count_mob = media_count
    assign media_1_mob = media_1
    assign media_2_mob = media_2
  endif

  assign overlay_bg = 'transparent'
  if section.settings.toggle_overlay
    if section.settings.overlay_style == 'gradient'
      assign overlay_bg = 'linear-gradient(' | append: section.settings.gradient_direction | append: ', ' | append: section.settings.overlay_color | append: ', transparent)'
    else
      assign overlay_bg = section.settings.overlay_color
    endif
  endif

  assign has_only_video = false
  if media_1 != 'image' and media_2 != 'image' and media_count > 0
    assign has_only_video = true
  endif

  case section.settings.section_height
    when 'small'
      assign section_min_height = '50svh'
    when 'medium'
      assign section_min_height = '65svh'
    when 'large'
      assign section_min_height = '80svh'
    when 'full'
      assign section_min_height = '100svh'
    when 'custom'
      assign section_min_height = section.settings.section_height_custom | append: 'px'
    else
      assign section_min_height = 'auto'
  endcase

  assign content_class = 'hero-content'
  if section.settings.section_width == 'page'
    assign content_class = content_class | append: ' hero-content--page'
  endif
%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --hero-min-height: {{ section_min_height }};
    --hero-overlay-bg: {{ overlay_bg }};
    --hero-blur-opacity: {{ section.settings.reflection_opacity | divided_by: 100.0 }};
    --hero-gap: {{ section.settings.gap }}px;
    --hero-pt: {{ section.settings.padding_top }}px;
    --hero-pb: {{ section.settings.padding_bottom }}px;
    --hero-media-count: {{ media_count }};
    --hero-media-count-mob: {{ media_count_mob }};
    --hero-content-align: {% case section.settings.h_align %}
      {% when 'left' %}flex-start
      {% when 'center' %}center
      {% when 'right' %}flex-end
      {% else %}flex-start
    {% endcase %};
    --hero-v-align: {% case section.settings.v_align %}
      {% when 'top' %}flex-start
      {% when 'center' %}center
      {% when 'bottom' %}flex-end
      {% else %}center
    {% endcase %};
  }

  /* ── Hero Badge Block Styles ── */
  .hero-badge {
    display: inline-block;
    padding: 0.4rem 1.2rem;
    background: var(--hero-badge-bg, rgba(255,255,255,0.2));
    color: var(--hero-badge-color, #ffffff);
    font-size: var(--hero-badge-size, 1.2rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    border-radius: 50px;
    backdrop-filter: blur(4px);
    line-height: 1.2;
    text-decoration: none;
    transition: 0.2s;
  }
  @media (min-width: 750px) {
    .hero-badge {
      font-size: var(--hero-badge-size-desktop, 1.4rem);
      padding: 0.6rem 1.6rem;
    }
  }

  /* ── Subheading Block Styles ── */
  .hero-subheading {
    margin: 0 0 var(--hero-subheading-margin, 0.5rem);
    font-family: var(--font-body-family);
    font-weight: var(--font-body-weight);
    line-height: 1.4;
    color: var(--hero-subheading-color, currentColor);
    font-size: var(--hero-subheading-size, 1.2rem);
  }
  @media (min-width: 750px) {
    .hero-subheading {
      font-size: var(--hero-subheading-size-desktop, 1.4rem);
    }
  }

  /* ── Heading Block Styles ── */
  .hero-heading {
    margin: 0;
    font-weight: bold;
    line-height: 1.2;
    color: var(--hero-heading-color, #ffffff);
    font-size: var(--hero-heading-size-mobile, 32px);
  }
  @media (min-width: 750px) {
    .hero-heading {
      font-size: var(--hero-heading-size-desktop, 48px);
    }
  }

  /* ── Button Block Styles ── */
  .hero-button {
    display: inline-block;
    padding: 0.8rem 2rem;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: 0.2s;
    font-size: var(--hero-button-size-mobile, 14px);
    cursor: pointer;
  }
  .hero-button--solid {
    background: var(--hero-button-bg, #ffffff);
    color: var(--hero-button-color, #000000);
    border: 1px solid transparent;
  }
  .hero-button--outline {
    background: transparent;
    color: var(--hero-button-color, #ffffff);
    border: 1px solid currentColor;
  }
  @media (min-width: 750px) {
    .hero-button {
      font-size: var(--hero-button-size-desktop, 16px);
      padding: 1rem 2.5rem;
    }
  }

  {% if section.settings.custom_css != blank %}
    #shopify-section-{{ section.id }} {
      {{ section.settings.custom_css }}
    }
  {% endif %}
{%- endstyle -%}

{%- if section.settings.section_link != blank -%}
  <a href="{{ section.settings.section_link }}" class="hero-section-link" {% if section.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %} aria-label="{{ 'accessibility.section_link' | t | default: 'Section link' }}"></a>
{%- endif -%}

<div class="hero{% if section.settings.stack_media_on_mobile %} hero--stack-mobile{% endif %}{% if section.settings.section_height == 'auto' and section.blocks.size == 0 %} hero--auto-height{% endif %}" id="Hero-{{ section.id }}" {% if section.settings.blurred_reflection and has_only_video == false %} data-blur-shadow="true"{% endif %}>

  <div class="hero__media-grid">
    {% if section.settings.toggle_overlay %}
      <div class="hero__overlay" aria-hidden="true"></div>
    {% endif %}

    {% if section.settings.blurred_reflection and has_only_video == false %}
      <div class="hero__blur hero__blur--desktop" aria-hidden="true">
        {% if media_1 == 'image' %}
          {{ section.settings.image_1 | image_url: width: 1800 | image_tag: class: 'hero__blur-img', alt: '' }}
        {% endif %}
        {% if media_2 == 'image' %}
          {{ section.settings.image_2 | image_url: width: 1800 | image_tag: class: 'hero__blur-img', alt: '' }}
        {% endif %}
        {% if media_count == 0 %}
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__blur-img' }}
        {% endif %}
      </div>
    {% endif %}

    {% if media_1 == 'image' %}
      <div class="hero__media-wrap hero__media-wrap--desktop">
        {{ section.settings.image_1 | image_url: width: 3840 | image_tag: class: 'hero__media', loading: 'eager', fetchpriority: 'high', widths: '768,1200,1800,2560,3840', sizes: '(min-width: 750px) 100vw, 100vw', alt: section.settings.image_1.alt | escape }}
      </div>
    {% elsif media_1 == 'video' %}
      <div class="hero__media-wrap hero__media-wrap--desktop">
        {{ section.settings.video_1 | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'hero__media' }}
      </div>
    {% endif %}

    {% if media_2 == 'image' %}
      <div class="hero__media-wrap hero__media-wrap--desktop">
        {{ section.settings.image_2 | image_url: width: 3840 | image_tag: class: 'hero__media', loading: 'eager', widths: '768,1200,1800,2560,3840', sizes: '(min-width: 750px) 50vw, 100vw', alt: section.settings.image_2.alt | escape }}
      </div>
    {% elsif media_2 == 'video' %}
      <div class="hero__media-wrap hero__media-wrap--desktop">
        {{ section.settings.video_2 | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'hero__media' }}
      </div>
    {% endif %}

    {% if section.settings.custom_mobile_media and media_count_mob > 0 %}
      {% if media_1_mob == 'image' %}
        <div class="hero__media-wrap hero__media-wrap--mobile">
          {{ section.settings.image_1_mob | image_url: width: 1200 | image_tag: class: 'hero__media', loading: 'eager', widths: '400,600,800,1200', sizes: '100vw', alt: section.settings.image_1_mob.alt | escape }}
        </div>
      {% elsif media_1_mob == 'video' %}
        <div class="hero__media-wrap hero__media-wrap--mobile">
          {{ section.settings.video_1_mob | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'hero__media' }}
        </div>
      {% endif %}

      {% if media_2_mob == 'image' %}
        <div class="hero__media-wrap hero__media-wrap--mobile">
          {{ section.settings.image_2_mob | image_url: width: 1200 | image_tag: class: 'hero__media', loading: 'eager', widths: '400,600,800,1200', sizes: '100vw', alt: section.settings.image_2_mob.alt | escape }}
        </div>
      {% elsif media_2_mob == 'video' %}
        <div class="hero__media-wrap hero__media-wrap--mobile">
          {{ section.settings.video_2_mob | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'hero__media' }}
        </div>
      {% endif %}
    {% endif %}

    {% if media_count == 0 %}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero__media hero__media--placeholder' }}
    {% endif %}
  </div>

  <div class="{{ content_class }}">
    <div class="hero__inner hero__inner--{{ section.settings.content_direction }}{% if section.settings.align_baseline %} hero__inner--baseline{% endif %}">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'hero-badge' %}
            <div class="hero-badge" style="
              --hero-badge-bg: {{ block.settings.background_color }};
              --hero-badge-color: {{ block.settings.text_color }};
              --hero-badge-size: {{ block.settings.font_size_mobile }}px;
              --hero-badge-size-desktop: {{ block.settings.font_size_desktop }}px;
            " {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {% when 'subheading' %}
            <div class="hero-subheading" style="
              --hero-subheading-color: {{ block.settings.text_color }};
              --hero-subheading-size: {{ block.settings.font_size_mobile }}px;
              --hero-subheading-size-desktop: {{ block.settings.font_size_desktop }}px;
              --hero-subheading-margin: {{ block.settings.margin_bottom }}px;
            " {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {% when 'heading' %}
            <{{ block.settings.heading_tag }} class="hero-heading" style="
              --hero-heading-color: {{ block.settings.text_color }};
              --hero-heading-size-mobile: {{ block.settings.font_size_mobile }}px;
              --hero-heading-size-desktop: {{ block.settings.font_size_desktop }}px;
            " {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </{{ block.settings.heading_tag }}>
          {% when 'button' %}
            <a href="{{ block.settings.link }}" class="hero-button hero-button--{{ block.settings.button_style }}" style="
              --hero-button-bg: {{ block.settings.background_color }};
              --hero-button-color: {{ block.settings.text_color }};
              --hero-button-size-mobile: {{ block.settings.font_size_mobile }}px;
              --hero-button-size-desktop: {{ block.settings.font_size_desktop }}px;
            " {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </a>
        {% endcase %}
      {% endfor %}
    </div>
  </div>

</div>

{% stylesheet %}
  .hero {
    position: relative;
    min-height: var(--hero-min-height, 65svh);
    display: flex;
    align-items: var(--hero-v-align, center);
    overflow: hidden;
  }
  .hero__media-grid {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(var(--hero-media-count, 1), 1fr);
  }
  .hero--auto-height .hero__media-grid {
    position: relative;
  }
  .hero__media-wrap {
    overflow: hidden;
    position: relative;
  }
  .hero__media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .hero__media--placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__media-wrap--mobile  { display: none; }
  .hero__media-wrap--desktop { display: block; }
  @media (max-width: 749px) {
    .hero__media-wrap--desktop { display: none; }
    .hero__media-wrap--mobile  { display: block; }
    .hero__media-grid {
      grid-template-columns: repeat(var(--hero-media-count-mob, 1), 1fr);
    }
    .hero--stack-mobile .hero__media-grid {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(var(--hero-media-count-mob, 1), 1fr);
    }
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: var(--hero-overlay-bg, transparent);
    pointer-events: none;
    z-index: 1;
  }
  .hero[data-blur-shadow='true'] {
    --blur-filter: blur(24px) saturate(1.6);
    --blur-mask: linear-gradient(to bottom, rgba(0,0,0,0.9) 0%, transparent 100%);
  }
  .hero__blur {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    mask-image: var(--blur-mask);
    -webkit-mask-image: var(--blur-mask);
    transform: translateY(52%);
    overflow: hidden;
  }
  .hero__blur-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: var(--blur-filter);
    opacity: var(--hero-blur-opacity, 0.75);
    transform: scale(2, 1.3);
  }
  .hero__blur--desktop {
    display: none;
    @media screen and (min-width: 750px) { display: block; }
  }
  .hero-section-link {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: var(--hero-pt, 0px);
    padding-bottom: var(--hero-pb, 0px);
    padding-inline: clamp(1rem, 4vw, 2.5rem);
    pointer-events: none;
  }
  .hero-content--page {
    max-width: 1400px;
    margin-inline: auto;
  }
  .hero-content :is(a, button, input, select, textarea, details) {
    pointer-events: auto;
  }
  .hero__inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--hero-gap, 16px);
    align-items: var(--hero-v-align, center);
    justify-content: var(--hero-content-align, flex-start);
  }
  .hero__inner--column {
    flex-direction: column;
    align-items: var(--hero-content-align, flex-start);
  }
  .hero__inner--row {
    flex-direction: row;
  }
  .hero__inner--baseline {
    align-items: baseline;
  }
  @media (max-width: 749px) {
    .hero__inner--row {
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Section",
  "tag": "section",
  "class": "hero-wrapper",
  "blocks": [
    {
      "type": "hero-badge",
      "name": "Hero Badge",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Badge Text",
          "default": "NEW ARRIVAL"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Background Color",
          "default": "#00000080"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "font_size_mobile",
          "label": "Font Size (Mobile)",
          "min": 10,
          "max": 24,
          "step": 1,
          "default": 12,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "font_size_desktop",
          "label": "Font Size (Desktop)",
          "min": 10,
          "max": 32,
          "step": 1,
          "default": 14,
          "unit": "px"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Subheading Text",
          "default": "Discover our latest collection"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "font_size_mobile",
          "label": "Font Size (Mobile)",
          "min": 12,
          "max": 28,
          "step": 1,
          "default": 14,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "font_size_desktop",
          "label": "Font Size (Desktop)",
          "min": 12,
          "max": 40,
          "step": 1,
          "default": 18,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "label": "Bottom Margin",
          "min": 0,
          "max": 40,
          "step": 2,
          "default": 8,
          "unit": "px"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Heading Text",
          "default": "Welcome to our store"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#FFFFFF"
        },
        {
          "type": "range",
          "id": "font_size_mobile",
          "label": "Font Size (Mobile)",
          "min": 20,
          "max": 60,
          "step": 2,
          "default": 32,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "font_size_desktop",
          "label": "Font Size (Desktop)",
          "min": 30,
          "max": 96,
          "step": 2,
          "default": 48,
          "unit": "px"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "HTML Tag",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "div", "label": "Div" }
          ],
          "default": "h2"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Background Color",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "font_size_mobile",
          "label": "Font Size (Mobile)",
          "min": 12,
          "max": 24,
          "step": 1,
          "default": 14,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "font_size_desktop",
          "label": "Font Size (Desktop)",
          "min": 14,
          "max": 32,
          "step": 1,
          "default": 16,
          "unit": "px"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button Style",
          "options": [
            { "value": "solid", "label": "Solid" },
            { "value": "outline", "label": "Outline" }
          ],
          "default": "solid"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Media 1"
    },
    {
      "type": "select",
      "id": "media_type_1",
      "label": "Media 1 Type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "video",
      "id": "video_1",
      "label": "Video 1"
    },
    {
      "type": "header",
      "content": "Media 2"
    },
    {
      "type": "select",
      "id": "media_type_2",
      "label": "Media 2 Type",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" }
      ],
      "default": "none"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "video",
      "id": "video_2",
      "label": "Video 2"
    },
    {
      "type": "header",
      "content": "Mobile Media"
    },
    {
      "type": "checkbox",
      "id": "stack_media_on_mobile",
      "label": "Stack media on mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "custom_mobile_media",
      "label": "Use different media on mobile",
      "default": false
    },
    {
      "type": "select",
      "id": "media_type_1_mob",
      "label": "Mobile Media 1 Type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" }
      ],
      "default": "image"
