{{ 'product-template.css' | asset_url | stylesheet_tag }}
{{ 'product-variant.js' | asset_url | script_tag }}

<style>
  #pt-{{ section.id }} {
    --pt-bg:         {{ section.settings.color_bg }};
    --pt-text:       {{ section.settings.color_text }};
    --pt-mid:        {{ section.settings.color_secondary_text }};
    --pt-border:     {{ section.settings.color_border }};
    --pt-btn-bg:     {{ section.settings.color_btn_bg }};
    --pt-btn-text:   {{ section.settings.color_btn_text }};
    --pt-price:      {{ section.settings.color_price }};
    --pt-badge-bg:   {{ section.settings.color_badge_bg }};
    --pt-badge-text: {{ section.settings.color_badge_text }};
    --pt-accent:     {{ section.settings.color_accent }};
    --pt-transition: all 0.3s ease;
    --pt-radius:     8px;
    background-color: var(--pt-bg);
    color:            var(--pt-text);
    padding-top:      {{ section.settings.padding_top }}px;
    padding-bottom:   {{ section.settings.padding_bottom }}px;
  }
</style>

<div id="pt-{{ section.id }}">
  <div
    class="pt-container"
    style="max-width:{{ section.settings.max_width }}px; margin:0 auto; padding:0 1rem;"
  >

    {%- if section.settings.show_breadcrumb -%}
    <nav
      aria-label="Breadcrumb"
      style="margin-bottom:2rem; font-size:0.875rem; color:var(--pt-mid);"
    >
      <a href="/" style="color:var(--pt-mid); text-decoration:none;">
        {{ section.settings.label_home | default: 'Home' }}
      </a>
      <span style="margin:0 0.4rem;">{{ section.settings.breadcrumb_sep | default: '/' }}</span>
      {%- if collection -%}
        <a href="{{ collection.url }}" style="color:var(--pt-mid); text-decoration:none;">
          {{ collection.title }}
        </a>
      {%- else -%}
        <a href="/collections/all" style="color:var(--pt-mid); text-decoration:none;">
          {{ section.settings.label_shop | default: 'Shop' }}
        </a>
      {%- endif -%}
      <span style="margin:0 0.4rem;">{{ section.settings.breadcrumb_sep | default: '/' }}</span>
      <span aria-current="page">{{ product.title }}</span>
    </nav>
    {%- endif -%}

    <div
      style="
        display: grid;
        grid-template-columns: {% if section.settings.layout == 'stacked' %}1fr{% else %}1fr 1fr{% endif %};
        gap: {{ section.settings.column_gap }}px;
        align-items: start;
      "
    >
      {% content_for "block", type: "product-media",   id: "product-media-static" %}
      {% content_for "block", type: "product-details", id: "product-details-static" %}
    </div>

  </div>
</div>

<script id="ProductJson-{{ section.id }}" type="application/json">
  {{ product | json }}
</script>

<script src="{{ 'product-template.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product Template",
  "class": "product-template",
  "blocks": [
    { "type": "product-media"        },
    { "type": "product-details"      },
    { "type": "product-title"        },
    { "type": "product-price"        },
    { "type": "price"                },
    { "type": "product-variants"     },
    { "type": "product-description"  },
    { "type": "product-buy-buttons"  },
    { "type": "product-accordion"    },
    { "type": "add_to_cart"          },
    { "type": "rating"               },
    { "type": "stock"                },
    { "type": "heading"              },
    { "type": "subheading"           },
    { "type": "divider"              },
    { "type": "custom_text"          },
    { "type": "image"                },
    { "type": "button"               },
    { "type": "features"             },
    { "type": "icon"                 },
    { "type": "reviews"              },
    { "type": "vendor"               },
    { "type": "@app"                 }
  ],
  "settings": [
    { "type": "header", "content": "🎨 Color Scheme" },
    { "type": "color", "id": "color_bg",             "label": "Background",        "default": "#ffffff" },
    { "type": "color", "id": "color_text",           "label": "Primary text",      "default": "#111111" },
    { "type": "color", "id": "color_secondary_text", "label": "Secondary text",    "default": "#6b7280" },
    { "type": "color", "id": "color_border",         "label": "Border",            "default": "#e5e7eb" },
    { "type": "color", "id": "color_btn_bg",         "label": "Button background", "default": "#111111" },
    { "type": "color", "id": "color_btn_text",       "label": "Button text",       "default": "#ffffff" },
    { "type": "color", "id": "color_price",          "label": "Price color",       "default": "#111111" },
    { "type": "color", "id": "color_accent",         "label": "Accent color",      "default": "#b45309" },
    { "type": "color", "id": "color_badge_bg",       "label": "Sale badge bg",     "default": "#111111" },
    { "type": "color", "id": "color_badge_text",     "label": "Sale badge text",   "default": "#ffffff" },

    { "type": "header", "content": "📐 Layout" },
    {
      "type": "select", "id": "layout", "label": "Layout",
      "options": [
        { "label": "Image left, Info right", "value": "media-left"  },
        { "label": "Image right, Info left", "value": "media-right" },
        { "label": "Stacked (full width)",   "value": "stacked"     }
      ],
      "default": "media-left"
    },
    { "type": "range", "id": "max_width",      "label": "Max width (px)",      "min": 900, "max": 1600, "step": 50, "default": 1400 },
    { "type": "range", "id": "column_gap",     "label": "Column gap (px)",     "min": 16,  "max": 120,  "step": 4,  "default": 48   },
    { "type": "range", "id": "padding_top",    "label": "Padding top (px)",    "min": 0,   "max": 120,  "step": 4,  "default": 32   },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 0,   "max": 120,  "step": 4,  "default": 80   },

    { "type": "header", "content": "🧭 Breadcrumb" },
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true   },
    { "type": "text",     "id": "label_home",      "label": "Home label",      "default": "Home" },
    { "type": "text",     "id": "label_shop",      "label": "Shop label",      "default": "Shop" },
    { "type": "text",     "id": "breadcrumb_sep",  "label": "Separator",       "default": "/"    }
  ],
  "presets": [
    {
      "name": "Product Template",
      "blocks": [
        {
          "type": "product-media",
          "id": "product-media-static",
          "static": true
        },
        {
          "type": "product-details",
          "id": "product-details-static",
          "static": true,
          "blocks": [
            { "type": "product-title",       "static": true, "id": "title-static"       },
            { "type": "product-price",       "static": true, "id": "price-static"       },
            { "type": "product-variants",    "static": true, "id": "variants-static"    },
            { "type": "product-description", "static": true, "id": "description-static" },
            { "type": "product-buy-buttons", "static": true, "id": "buttons-static"     },
            { "type": "product-accordion",   "static": true, "id": "accordion-static"   }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
