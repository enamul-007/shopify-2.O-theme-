{% style %}
  .image-banner-{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ section.settings.section_radius }}px;
  }

  .image-banner-{{ section.id }} .banner-media {
    position: relative;
    width: 100%;
    min-height: {{ section.settings.banner_height }}px;
    display: block;
  }

  .image-banner-{{ section.id }} .banner-media img,
  .image-banner-{{ section.id }} .banner-media .placeholder-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .image-banner-{{ section.id }} .banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }}) 0%,
      rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 200.0 }}) 55%,
      transparent 100%
    );
  }

  .image-banner-{{ section.id }} .banner-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: {{ section.settings.vertical_align }};
    justify-content: {{ section.settings.horizontal_align }};
    padding: {{ section.settings.padding_vertical }}px {{ section.settings.padding_horizontal }}px;
  }

  .image-banner-{{ section.id }} .banner-content {
    max-width: {{ section.settings.content_width }}%;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.content_gap }}px;
    text-align: {{ section.settings.text_align }};
  }

  @media (max-width: 768px) {
    .image-banner-{{ section.id }} .banner-media { min-height: 500px; }
    .image-banner-{{ section.id }} .banner-inner {
      padding: 2rem 1.5rem;
      align-items: flex-end;
    }
    .image-banner-{{ section.id }} .banner-content { max-width: 100%; }
    .image-banner-{{ section.id }} .banner-overlay {
      background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.2) 60%, transparent 100%);
    }
  }
{% endstyle %}

<div class="image-banner-{{ section.id }}">
  <div class="banner-media">

    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 1500
        | image_tag:
          widths: '375,550,750,1100,1500',
          fetchpriority: 'high',
          loading: 'eager',
          alt: 'Banner image'
      }}
    {% else %}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}

    <div class="banner-overlay"></div>

    <div class="banner-inner">
      <div class="banner-content">

        {% for block in section.blocks %}
          {% case block.type %}

            {% when 'badge' %}
              <span class="banner-badge-{{ block.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.badge_text }}
              </span>
              {% style %}
                .banner-badge-{{ block.id }} {
                  display: inline-block;
                  font-size: {{ block.settings.font_size }}px;
                  font-weight: {{ block.settings.font_weight }};
                  letter-spacing: {{ block.settings.letter_spacing }}px;
                  text-transform: {{ block.settings.text_transform }};
                  color: {{ block.settings.text_color }};
                  background: {{ block.settings.bg_color }};
                  border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
                  padding: {{ block.settings.padding_v }}px {{ block.settings.padding_h }}px;
                  border-radius: {{ block.settings.border_radius }}px;
                  width: fit-content;
                  {% if section.settings.text_align == 'center' %}margin: 0 auto;{% endif %}
                }
              {% endstyle %}

            {% when 'heading' %}
              <h2 class="banner-heading-{{ block.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.heading }}
              </h2>
              {% style %}
                .banner-heading-{{ block.id }} {
                  font-size: clamp(
                    {{ block.settings.font_size_mobile }}px,
                    {{ block.settings.font_size_fluid }}vw,
                    {{ block.settings.font_size }}px
                  );
                  font-weight: {{ block.settings.font_weight }};
                  color: {{ block.settings.text_color }};
                  line-height: {{ block.settings.line_height }};
                  letter-spacing: {{ block.settings.letter_spacing }}px;
                  text-transform: {{ block.settings.text_transform }};
                  margin: 0;
                }
              {% endstyle %}

            {% when 'subheading' %}
              <div class="banner-sub-{{ block.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.sub_heading }}
              </div>
              {% style %}
                .banner-sub-{{ block.id }} {
                  font-size: {{ block.settings.font_size }}px;
                  font-weight: {{ block.settings.font_weight }};
                  color: {{ block.settings.text_color }};
                  line-height: {{ block.settings.line_height }};
                  max-width: {{ block.settings.max_width }}px;
                  margin: 0;
                  {% if section.settings.text_align == 'center' %}margin-left: auto; margin-right: auto;{% endif %}
                }
                .banner-sub-{{ block.id }} p { margin: 0; }
              {% endstyle %}

            {% when 'buttons' %}
              <div class="banner-cta-{{ block.id }}" {{ block.shopify_attributes }}>
                {% if block.settings.label_1 != blank %}
                  <a href="{{ block.settings.url_1 }}" class="btn-primary-{{ block.id }}">
                    {{ block.settings.label_1 }}
                  </a>
                {% endif %}
                {% if block.settings.label_2 != blank %}
                  <a href="{{ block.settings.url_2 }}" class="btn-secondary-{{ block.id }}">
                    {{ block.settings.label_2 }}
                  </a>
                {% endif %}
              </div>
              {% style %}
                .banner-cta-{{ block.id }} {
                  display: flex;
                  gap: {{ block.settings.btn_gap }}px;
                  flex-wrap: wrap;
                  align-items: center;
                  {% if section.settings.text_align == 'center' %}justify-content: center;{% endif %}
                }
                .btn-primary-{{ block.id }} {
                  display: inline-block;
                  padding: {{ block.settings.btn_padding_v }}px {{ block.settings.btn_padding_h }}px;
                  font-size: {{ block.settings.btn_font_size }}px;
                  font-weight: {{ block.settings.btn_font_weight }};
                  letter-spacing: {{ block.settings.btn_letter_spacing }}px;
                  text-transform: {{ block.settings.btn_text_transform }};
                  color: {{ block.settings.btn1_text_color }};
                  background: {{ block.settings.btn1_bg }};
                  border: {{ block.settings.btn1_border_width }}px solid {{ block.settings.btn1_border_color }};
                  border-radius: {{ block.settings.btn_radius }}px;
                  text-decoration: none;
                  transition: opacity 0.2s, transform 0.15s;
                }
                .btn-primary-{{ block.id }}:hover {
                  opacity: 0.85;
                  transform: translateY(-2px);
                }
                .btn-secondary-{{ block.id }} {
                  display: inline-block;
                  padding: {{ block.settings.btn_padding_v }}px {{ block.settings.btn_padding_h }}px;
                  font-size: {{ block.settings.btn_font_size }}px;
                  font-weight: {{ block.settings.btn_font_weight }};
                  letter-spacing: {{ block.settings.btn_letter_spacing }}px;
                  text-transform: {{ block.settings.btn_text_transform }};
                  color: {{ block.settings.btn2_text_color }};
                  background: {{ block.settings.btn2_bg }};
                  border: {{ block.settings.btn2_border_width }}px solid {{ block.settings.btn2_border_color }};
                  border-radius: {{ block.settings.btn_radius }}px;
                  text-decoration: none;
                  transition: background 0.2s, transform 0.15s;
                }
                .btn-secondary-{{ block.id }}:hover {
                  opacity: 0.85;
                  transform: translateY(-2px);
                }
              {% endstyle %}

          {% endcase %}
        {% endfor %}

      </div>
    </div>
  </div>
</div>

