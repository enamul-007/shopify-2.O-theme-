{%- style -%}
  .new-arrivals-section {
    padding: 4rem 0;
  }
  @media (min-width: 768px) {
    .new-arrivals-section {
      padding: 6rem 0;
    }
  }

  .new-arrivals-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }

  .new-arrivals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .new-arrivals-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .new-arrivals-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
{%- endstyle -%}

<section class="new-arrivals-section" id="shopify-section-{{ section.id }}">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="new-arrivals-header">
      <div>
        <h2 class="text-3xl md:text-4xl font-medium tracking-tight">
          {{ section.settings.heading }}
        </h2>
        <p class="text-gray-600 mt-2 text-lg">
          {{ section.settings.subheading }}
        </p>
      </div>
      
      
    </div>

    <!-- Products Grid -->
    <div class="new-arrivals-grid">
      {% if section.settings.collection != blank %}
        
        {% for product in section.settings.collection.products limit: 8 %}
          
          {%- comment -%} Auto NEW (last 7 days) fallback {%- endcomment -%}
          {% assign created_ts = product.created_at | date: '%s' %}
          {% assign now_ts = 'now' | date: '%s' %}
          {% assign diff_days = now_ts | minus: created_ts | divided_by: 86400 %}

          {% if diff_days < 7 %}
            {% assign is_auto_new = true %}
          {% else %}
            {% assign is_auto_new = false %}
          {% endif %}

          {% render 'product-card',
            product: product,
            index: forloop.index0,
            is_auto_new: is_auto_new
          %}
          
        {% endfor %}

      {% else %}
        <!-- Placeholder when no products -->
        {% for i in (1..4) %}
          <div class="col-span-1">
            <div class="bg-gray-100 rounded-2xl aspect-[3/4] flex items-center justify-center">
              <p class="text-gray-400">Product {{ i }}</p>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <!-- Mobile View All Button -->
    <div class="mt-10 text-center md:hidden">
      <a href="{{ section.settings.button_link }}" 
         class="inline-flex items-center gap-2 text-gray-900 font-medium">
        {{ section.settings.button_text }}
        
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "New Arrivals",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Fresh designs, just added to our collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection",
      "info": "Only products from this collection will be shown"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "info": "Usually link to your New Arrivals collection"
    }
  ],
  "presets": [
    {
      "name": "New Arrivals"
    }
  ]
}
{% endschema %}