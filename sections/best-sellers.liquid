{%- style -%}
  #shopify-section-{{ section.id }} .bestsellers-section {
    padding: {{ section.settings.padding_v_mobile }}px 0;
    background-color: {{ section.settings.color_scheme.settings.background }};
    color: {{ section.settings.color_scheme.settings.text }};
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .bestsellers-section {
      padding: {{ section.settings.padding_v_desktop }}px 0;
    }
  }

  #shopify-section-{{ section.id }} .bestsellers-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    #shopify-section-{{ section.id }} .bestsellers-inner { padding: 0 1.5rem; }
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .bestsellers-inner { padding: 0 2rem; }
  }

  {% comment %} ── Header Row ── {% endcomment %}
  #shopify-section-{{ section.id }} .bestsellers-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  #shopify-section-{{ section.id }} .bestsellers-header.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #shopify-section-{{ section.id }} .bestsellers-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    margin: 0 0 0.75rem 0;
    color: {{ section.settings.color_scheme.settings.text }};
  }

  #shopify-section-{{ section.id }} .bestsellers-subtitle {
    color: {{ section.settings.color_scheme.settings.secondary_button_label }};
    margin: 0;
    font-size: 1rem;
  }

  #shopify-section-{{ section.id }} .view-all-desktop {
    display: none;
    align-items: center;
    gap: 0.5rem;
    color: {{ section.settings.color_scheme.settings.text }};
    text-decoration: none;
    font-size: 0.95rem;
    white-space: nowrap;
    transition: gap 0.2s ease;
    flex-shrink: 0;
    margin-left: 2rem;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .view-all-desktop { display: inline-flex; }
  }

  #shopify-section-{{ section.id }} .view-all-desktop:hover {
    gap: 0.75rem;
  }

  #shopify-section-{{ section.id }} .view-all-desktop .arrow-icon {
    transition: transform 0.2s ease;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .view-all-desktop:hover .arrow-icon {
    transform: translateX(4px);
  }

  {% comment %} ── Product Grid ── {% endcomment %}
  #shopify-section-{{ section.id }} .bestsellers-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    #shopify-section-{{ section.id }} .bestsellers-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .bestsellers-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: 2rem;
    }
  }

  {% comment %} ── Product Card ── {% endcomment %}
  #shopify-section-{{ section.id }} .product-card {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  #shopify-section-{{ section.id }} .product-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #shopify-section-{{ section.id }} .product-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .product-img-wrap {
    aspect-ratio: 1 / 1;
    background-color: {{ section.settings.color_scheme.settings.background }};
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    margin-bottom: 1rem;
    position: relative;
  }

  #shopify-section-{{ section.id }} .product-img-wrap img,
  #shopify-section-{{ section.id }} .product-img-wrap svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  #shopify-section-{{ section.id }} .product-card-link:hover .product-img-wrap img {
    transform: scale(1.05);
  }

  #shopify-section-{{ section.id }} .product-info {
    padding: 0 0.25rem;
  }

  #shopify-section-{{ section.id }} .product-vendor {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: {{ section.settings.color_scheme.settings.secondary_button_label }};
    margin: 0 0 0.35rem 0;
  }

  #shopify-section-{{ section.id }} .product-title {
    font-size: 1rem;
    font-weight: 500;
    margin: 0 0 0.5rem 0;
    color: {{ section.settings.color_scheme.settings.text }};
    transition: color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .product-card-link:hover .product-title {
    color: {{ section.settings.color_scheme.settings.secondary_button_label }};
  }

  #shopify-section-{{ section.id }} .product-price {
    font-size: 0.95rem;
    font-weight: 600;
    color: {{ section.settings.color_scheme.settings.text }};
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .price-compare {
    font-weight: 400;
    text-decoration: line-through;
    color: {{ section.settings.color_scheme.settings.secondary_button_label }};
    font-size: 0.875rem;
  }

  #shopify-section-{{ section.id }} .price-sale {
    color: #dc2626;
  }

  {% comment %} ── Mobile View All ── {% endcomment %}
  #shopify-section-{{ section.id }} .view-all-mobile {
    margin-top: 2rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .view-all-mobile { display: none; }
  }

  #shopify-section-{{ section.id }} .view-all-mobile a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: {{ section.settings.color_scheme.settings.text }};
    text-decoration: none;
    font-size: 0.95rem;
    transition: gap 0.2s ease;
  }

  #shopify-section-{{ section.id }} .view-all-mobile a:hover {
    gap: 0.75rem;
  }

  #shopify-section-{{ section.id }} .view-all-mobile .arrow-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .view-all-mobile a:hover .arrow-icon {
    transform: translateX(4px);
  }
{%- endstyle -%}

{%- liquid
  assign view_all_url = section.settings.view_all_url
  assign view_all_label = section.settings.view_all_label
-%}

<section class="bestsellers-section">
  <div class="bestsellers-inner">

    {% comment %} ── Header ── {% endcomment %}
    <div class="bestsellers-header js-reveal">
      <div>
        {% if section.settings.title != blank %}
          <h2 class="bestsellers-title">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.subtitle != blank %}
          <p class="bestsellers-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>

      {% if view_all_url != blank and view_all_label != blank %}
        <a href="{{ view_all_url }}" class="view-all-desktop">
          {{ view_all_label }}
          <svg class="arrow-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      {% endif %}
    </div>

    {% comment %} ── Product Grid ── {% endcomment %}
    <div class="bestsellers-grid">

      {% assign product_list = section.settings.collection.products %}

      {% if product_list.size > 0 %}
        {% assign limit = section.settings.products_count %}
        {% for product in product_list limit: limit %}
          <div
            class="product-card js-reveal"
            style="transition-delay: {{ forloop.index0 | times: 100 }}ms;"
          >
            <a href="{{ product.url }}" class="product-card-link">
              <div class="product-img-wrap">
                {% if product.featured_image %}
                  {{
                    product.featured_image
                    | image_url: width: 800
                    | image_tag:
                      widths: '300,400,600,800',
                      loading: 'lazy',
                      alt: product.title
                  }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag }}
                {% endif %}
              </div>
              <div class="product-info">
                {% if section.settings.show_vendor and product.vendor != blank %}
                  <p class="product-vendor">{{ product.vendor }}</p>
                {% endif %}
                <h3 class="product-title">{{ product.title }}</h3>
                <p class="product-price">
                  {% if product.compare_at_price > product.price %}
                    <span class="price-compare">{{ product.compare_at_price | money }}</span>
                    <span class="price-sale">{{ product.price | money }}</span>
                  {% else %}
                    <span>{{ product.price | money }}</span>
                  {% endif %}
                </p>
              </div>
            </a>
          </div>
        {% endfor %}

      {% else %}
        {% comment %} Placeholder cards in editor {% endcomment %}
        {% for i in (1..4) %}
          <div class="product-card js-reveal" style="transition-delay: {{ forloop.index0 | times: 100 }}ms;">
            <a href="#" class="product-card-link">
              <div class="product-img-wrap">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag }}
              </div>
              <div class="product-info">
                <h3 class="product-title">Sample Product {{ forloop.index }}</h3>
                <p class="product-price"><span>$99.00</span></p>
              </div>
            </a>
          </div>
        {% endfor %}
      {% endif %}

    </div>

    {% comment %} ── Mobile View All ── {% endcomment %}
    {% if view_all_url != blank and view_all_label != blank %}
      <div class="view-all-mobile">
        <a href="{{ view_all_url }}">
          {{ view_all_label }}
          <svg class="arrow-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    {% endif %}

  </div>
</section>

<script>
(function() {
  const items = document.querySelectorAll('#shopify-section-{{ section.id }} .js-reveal');
  if (!items.length) return;
  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  items.forEach(function(el) { observer.observe(el); });
})();
</script>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    {
      "type": "header",
      "content": "Color & Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Border Radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_v_mobile",
      "label": "Padding Top/Bottom (Mobile)",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_v_desktop",
      "label": "Padding Top/Bottom (Desktop)",
      "min": 40,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 96
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Customer favorites that stand the test of time"
    },
    {
      "type": "header",
      "content": "View All Button"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Button Label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of Products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (Desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show Vendor",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Best Sellers"
    }
  ]
}
{% endschema %}
