{%- style -%}
  #shopify-section-{{ section.id }} .bestsellers-section {
    padding: {{ section.settings.padding_v_mobile }}px 0;
    background-color: {{ section.settings.color_scheme.settings.background }};
    color: {{ section.settings.color_scheme.settings.text }};
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .bestsellers-section {
      padding: {{ section.settings.padding_v_desktop }}px 0;
    }
  }

  #shopify-section-{{ section.id }} .bestsellers-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    #shopify-section-{{ section.id }} .bestsellers-inner { padding: 0 1.5rem; }
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .bestsellers-inner { padding: 0 2rem; }
  }

  #shopify-section-{{ section.id }} .bestsellers-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 3rem;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  #shopify-section-{{ section.id }} .bestsellers-header.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #shopify-section-{{ section.id }} .bestsellers-title {
    font-size: {{ section.settings.title_size }}px;
    font-weight: {{ section.settings.title_weight }};
    color: {{ section.settings.color_scheme.settings.text }};
    margin: 0 0 0.75rem 0;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .bestsellers-subtitle {
    font-size: {{ section.settings.subtitle_size }}px;
    {%- if section.settings.subtitle_color_source == 'muted' -%}
      color: {{ section.settings.color_scheme.settings.secondary_button_label }};
    {%- else -%}
      color: {{ section.settings.color_scheme.settings.text }};
    {%- endif -%}
    margin: 0;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .bestsellers-blocks {
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .bestsellers-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    #shopify-section-{{ section.id }} .bestsellers-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .bestsellers-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: 2rem;
    }
  }

  #shopify-section-{{ section.id }} .product-card-wrap {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  #shopify-section-{{ section.id }} .product-card-wrap.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
{%- endstyle -%}

{%- liquid
  assign show_view_all = false
  if section.settings.collection == blank
    assign show_view_all = true
  elsif section.settings.collection.products_count > section.settings.products_count
    assign show_view_all = true
  endif
-%}

<section class="bestsellers-section">
  <div class="bestsellers-inner">

    <div class="bestsellers-header js-reveal">
      <div>
        {%- if section.settings.title != blank -%}
          {%- assign title_tag = section.settings.title_tag -%}
          <{{ title_tag }} class="bestsellers-title">{{ section.settings.title }}</{{ title_tag }}>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="bestsellers-subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>

      {%- if show_view_all -%}
        <div class="bestsellers-blocks">
          {% content_for 'blocks' %}
        </div>
      {%- endif -%}
    </div>

    <div class="bestsellers-grid">
      {%- assign product_list = section.settings.collection.products -%}

      {%- if product_list.size > 0 -%}
        {%- assign limit = section.settings.products_count -%}
        {%- for product in product_list limit: limit -%}
          <div
            class="product-card-wrap js-reveal"
            style="transition-delay: {{ forloop.index0 | times: 100 }}ms;"
          >
            {%- render 'product-card',
              product: product,
              card_radius: section.settings.card_radius,
              show_vendor: section.settings.show_vendor,
              color_scheme: section.settings.color_scheme
            -%}
          </div>
        {%- endfor -%}

      {%- else -%}
        {%- for i in (1..4) -%}
          <div
            class="product-card-wrap js-reveal"
            style="transition-delay: {{ forloop.index0 | times: 100 }}ms;"
          >
            {%- render 'product-card',
              product: nil,
              placeholder_index: forloop.index,
              card_radius: section.settings.card_radius,
              show_vendor: section.settings.show_vendor,
              color_scheme: section.settings.color_scheme
            -%}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

<script>
(function () {
  var items = document.querySelectorAll('#shopify-section-{{ section.id }} .js-reveal');
  if (!items.length) return;
  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  items.forEach(function (el) { observer.observe(el); });
})();
</script>

{% schema %}
{
  "name": "Best Sellers",
  "blocks": [
    {
      "type": "view-all-button"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Color & Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Border Radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_v_mobile",
      "label": "Padding Top/Bottom (Mobile)",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_v_desktop",
      "label": "Padding Top/Bottom (Desktop)",
      "min": 40,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 96
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title Text",
      "default": "Best Sellers"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Title HTML Tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title Font Size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Title Font Weight",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi Bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Subtitle"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle Text",
      "default": "Customer favorites that stand the test of time"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtitle Font Size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "subtitle_color_source",
      "label": "Subtitle Color",
      "options": [
        { "value": "muted", "label": "Muted (secondary)" },
        { "value": "text",  "label": "Main Text Color" }
      ],
      "default": "muted"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of Products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (Desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show Vendor",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Best Sellers"
    }
  ]
}
{% endschema %}