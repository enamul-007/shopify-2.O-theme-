{% comment %}
  sections/testimonial.liquid — Final Fixed Version
{% endcomment %}

<section
  class="ts-section"
  id="ts-{{ section.id }}"
  style="background-color: {{ section.settings.bg_color }};"
>
  <div class="ts-inner">

    <div class="ts-header" id="tsHeader-{{ section.id }}"></div>

    <div class="ts-slider-wrap" id="tsWrap-{{ section.id }}">
      <div class="ts-track" id="tsTrack-{{ section.id }}"></div>
    </div>

    <div
      class="ts-blocks-source"
      id="tsSource-{{ section.id }}"
      aria-hidden="true"
    >
      {% content_for 'blocks' %}
    </div>

    <div
      class="ts-nav"
      id="tsNav-{{ section.id }}"
      role="navigation"
      aria-label="Testimonial navigation"
    >
      <button class="ts-arr ts-arr--prev" id="tsPrev-{{ section.id }}" aria-label="Previous testimonial" disabled>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="ts-dots" id="tsDots-{{ section.id }}" role="tablist"></div>
      <button class="ts-arr ts-arr--next" id="tsNext-{{ section.id }}" aria-label="Next testimonial">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

  </div>
</section>

<style>
  #ts-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --ts-accent: {{ section.settings.accent_color }};
  }

  #ts-{{ section.id }} .ts-blocks-source {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
    pointer-events: none;
  }

  #ts-{{ section.id }} .ts-inner {
    max-width: 680px;
    margin: 0 auto;
    position: relative;
  }

  #ts-{{ section.id }} .ts-header {
    text-align: center;
    margin-bottom: 40px;
  }

  #ts-{{ section.id }} .ts-slider-wrap {
    overflow: hidden;
    width: 100%;
    display: block;
  }

  #ts-{{ section.id }} .ts-track {
    display: flex;
    flex-wrap: nowrap;
    width: 100%;
    transition: transform 0.48s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  #ts-{{ section.id }} .ts-slide {
    flex: 0 0 100%;
    display: flex;
    justify-content: center;
    padding: 0 4px;
    box-sizing: border-box;
    position: static !important;
    visibility: visible !important;
    clip: auto !important;
    clip-path: none !important;
    white-space: normal !important;
    overflow: visible !important;
    height: auto !important;
  }

  #ts-{{ section.id }} .ts-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 32px;
  }

  #ts-{{ section.id }} .ts-arr {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid #e0e0e0;
    background: #fff;
    cursor: pointer;
    color: #888;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color .15s, color .15s, box-shadow .15s;
    flex-shrink: 0;
  }

  #ts-{{ section.id }} .ts-arr:hover:not(:disabled) {
    border-color: var(--ts-accent);
    color: var(--ts-accent);
    box-shadow: 0 2px 8px rgba(0,0,0,.1);
  }

  #ts-{{ section.id }} .ts-arr:disabled {
    opacity: .3;
    cursor: default;
  }

  #ts-{{ section.id }} .ts-dots {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  #ts-{{ section.id }} .ts-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #d9d9d9;
    cursor: pointer;
    border: none;
    padding: 0;
    transition: background .2s, transform .2s;
  }

  #ts-{{ section.id }} .ts-dot--active {
    background: var(--ts-accent);
    transform: scale(1.25);
  }

  @media (max-width: 600px) {
    #ts-{{ section.id }} { padding-inline: 16px; }
  }
</style>

<script>
(function () {
  var id      = '{{ section.id }}';
  var source  = document.getElementById('tsSource-' + id);
  var header  = document.getElementById('tsHeader-' + id);
  var track   = document.getElementById('tsTrack-' + id);
  var prevBtn = document.getElementById('tsPrev-' + id);
  var nextBtn = document.getElementById('tsNext-' + id);
  var dotsEl  = document.getElementById('tsDots-' + id);
  var navEl   = document.getElementById('tsNav-' + id);

  if (!source || !track || !header) return;

  var slideEls = Array.from(source.querySelectorAll('.ts-slide'));

  Array.from(source.children).forEach(function (el) {
    if (!el.classList.contains('ts-slide') && !el.querySelector('.ts-slide')) {
      header.appendChild(el);
    }
  });

  slideEls.forEach(function (el) {
    track.appendChild(el);
  });

  var total = slideEls.length;
  var cur   = 0;
  var dots  = [];

  if (total === 0) return;

  if (total <= 1) {
    if (navEl) navEl.style.display = 'none';
  }

  function buildDots() {
    dotsEl.innerHTML = '';
    dots = [];
    for (var i = 0; i < total; i++) {
      var btn = document.createElement('button');
      btn.className = 'ts-dot' + (i === 0 ? ' ts-dot--active' : '');
      btn.setAttribute('aria-label', 'Go to slide ' + (i + 1));
      btn.setAttribute('role', 'tab');
      btn.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
      btn.dataset.index = i;
      btn.addEventListener('click', function () {
        go(parseInt(this.dataset.index, 10));
      });
      dotsEl.appendChild(btn);
      dots.push(btn);
    }
  }

  function go(n) {
    cur = Math.max(0, Math.min(n, total - 1));
    track.style.transform = 'translateX(-' + (cur * 100) + '%)';
    if (prevBtn) prevBtn.disabled = (cur === 0);
    if (nextBtn) nextBtn.disabled = (cur === total - 1);
    dots.forEach(function (d, i) {
      d.classList.toggle('ts-dot--active', i === cur);
      d.setAttribute('aria-selected', i === cur ? 'true' : 'false');
    });
  }

  if (prevBtn) prevBtn.addEventListener('click', function () { go(cur - 1); });
  if (nextBtn) nextBtn.addEventListener('click', function () { go(cur + 1); });

  var touchStartX = 0;
  track.addEventListener('touchstart', function (e) {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });
  track.addEventListener('touchend', function (e) {
    var diff = touchStartX - e.changedTouches[0].screenX;
    if (Math.abs(diff) > 40) {
      if (diff > 0) go(cur + 1);
      else          go(cur - 1);
    }
  }, { passive: true });

  document.getElementById('ts-' + id).addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  go(cur - 1);
    if (e.key === 'ArrowRight') go(cur + 1);
  });

  {% if section.settings.autoplay %}
  var autoInterval = setInterval(function () {
    go(cur < total - 1 ? cur + 1 : 0);
  }, {{ section.settings.autoplay_speed | times: 1000 }});

  document.getElementById('ts-' + id).addEventListener('mouseenter', function () {
    clearInterval(autoInterval);
  });
  {% endif %}

  buildDots();
  go(0);
})();
</script>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "testimonial-section",
  "blocks": [
    { "type": "@theme" },
    { "type": "@app" }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#d9735a"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Auto Play"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
