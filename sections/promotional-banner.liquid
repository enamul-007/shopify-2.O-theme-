{%- style -%}
  #shopify-section-{{ section.id }} .promo-section {
    position: relative;
    height: {{ section.settings.mobile_height }}px;
    background-color: {{ section.settings.color_scheme.settings.background }};
    color: {{ section.settings.color_scheme.settings.text }};
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .promo-section {
      height: {{ section.settings.tablet_height }}px;
    }
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .promo-section {
      height: {{ section.settings.desktop_height }}px;
    }
  }

  #shopify-section-{{ section.id }} .promo-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: {{ section.settings.image_opacity | divided_by: 100.0 }};
  }

  #shopify-section-{{ section.id }} .promo-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});
  }

  #shopify-section-{{ section.id }} .promo-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 1rem;
    max-width: 800px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;

    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  #shopify-section-{{ section.id }} .promo-inner.is-visible {
    opacity: 1;
    transform: scale(1);
  }
{%- endstyle -%}

<section class="promo-section">

  {% comment %} ── Background Image ── {% endcomment %}
  {% if section.settings.image != blank %}
    {{
      section.settings.image
      | image_url: width: 2000
      | image_tag:
        class: 'promo-bg',
        widths: '600,900,1200,1600,2000',
        fetchpriority: 'high',
        loading: 'eager',
        alt: 'Promotional banner'
    }}
  {% else %}
    {{ 'lifestyle-1' | placeholder_svg_tag: 'promo-bg' }}
  {% endif %}

  <div class="promo-overlay"></div>

  <div class="promo-inner js-promo-reveal">
    {% content_for 'blocks' %}
  </div>

</section>

<script>
(function() {
  var el = document.querySelector('#shopify-section-{{ section.id }} .js-promo-reveal');
  if (!el) return;
  if (!('IntersectionObserver' in window)) {
    el.classList.add('is-visible');
    return;
  }
  new IntersectionObserver(function(entries, obs) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        obs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 }).observe(el);
})();
</script>

{% schema %}
{
  "name": "Promotional Banner",
  "settings": [
    {
      "type": "header",
      "content": "Color & Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "image_opacity",
      "label": "Image Opacity",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Dark Overlay",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 20
    },
    {
      "type": "header",
      "content": "Height"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile Height",
      "min": 250,
      "max": 750,
      "step": 20,
      "unit": "px",
      "default": 450
    },
    {
      "type": "range",
      "id": "tablet_height",
      "label": "Tablet Height",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop Height",
      "min": 350,
      "max": 950,
      "step": 20,
      "unit": "px",
      "default": 510
    }
  ],
  "blocks": [
    {
      "type": "hero-badge"
    },
    {
      "type": "heading"
    },
    {
      "type": "subheading"
    },
    {
      "type": "button"
}
  ],
  "presets": [
    {
      "name": "Promotional Banner",
      "blocks": [
        {
          "type": "hero-badge"
        },
        {
          "type": "heading"
        },
        {
          "type": "subheading"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}