{% assign collection_products = section.settings.collection.products %}

<style>
  .fc-section {
    margin: 2rem 0;
  }
  .fc-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .fc-header .heading {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: #111827;
    margin: 0 0 0.5rem;
  }
  .fc-header .sub-heading {
    color: #6b7280;
    font-size: 0.9375rem;
  }

  /* ── 4-column grid ── */
  .fc-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 1024px) {
    .fc-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .fc-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  }
  @media (max-width: 480px) {
    .fc-grid { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
  }

  /* ── Placeholder cards (যখন কোনো product নেই) ── */
  .fc-placeholder-card {
    background: #f3f4f6;
    border-radius: 0.75rem;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .fc-placeholder-card svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }
</style>

<div class="fc-section">
  <div class="container">

    <div class="fc-header">
      <h2 class="heading">{{ section.settings.heading }}</h2>
      {% if section.settings.sub_heading != blank %}
        <div class="sub-heading">{{ section.settings.sub_heading }}</div>
      {% endif %}
    </div>

    <div class="fc-grid">
      {% for product in collection_products limit: 8 %}
        {% render 'product-card', product: product, index: forloop.index0 %}
      {% else %}
        {% for i in (1..8) %}
          <div class="fc-placeholder-card">
            {%- capture current -%}{%- cycle 1, 2, 3, 4 -%}{%- endcapture -%}
            {{ 'product-apparel-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endfor %}
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collection"
    },
    {
      "type": "richtext",
      "id": "sub_heading",
      "label": "Sub Heading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
