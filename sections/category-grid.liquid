{%- style -%}
  #shopify-section-{{ section.id }} .category-section {
    padding: {{ section.settings.padding_v_mobile }}px 0;
    background-color: {{ section.settings.color_scheme.settings.background }};
    color: {{ section.settings.color_scheme.settings.text }};
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .category-section {
      padding: {{ section.settings.padding_v_desktop }}px 0;
    }
  }

  #shopify-section-{{ section.id }} .category-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    #shopify-section-{{ section.id }} .category-inner { padding: 0 1.5rem; }
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .category-inner { padding: 0 2rem; }
  }

  {% comment %} ── Section Header ── {% endcomment %}
  #shopify-section-{{ section.id }} .category-header {
    text-align: center;
    margin-bottom: 3rem;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  #shopify-section-{{ section.id }} .category-header.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #shopify-section-{{ section.id }} .category-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    margin: 0 0 1rem 0;
    color: {{ section.settings.color_scheme.settings.text }};
  }

  #shopify-section-{{ section.id }} .category-subtitle {
    color: {{ section.settings.color_scheme.settings.secondary_button_label }};
    max-width: 42rem;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.6;
  }

  {% comment %} ── Grid ── {% endcomment %}
  #shopify-section-{{ section.id }} .category-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .category-grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
      gap: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .category-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }

  {% comment %} ── Category Card ── {% endcomment %}
  #shopify-section-{{ section.id }} .category-card {
    display: block;
    text-decoration: none;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  #shopify-section-{{ section.id }} .category-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #shopify-section-{{ section.id }} .category-img-wrap {
    aspect-ratio: 1 / 1;
    background-color: {{ section.settings.color_scheme.settings.background }};
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  #shopify-section-{{ section.id }} .category-img-wrap img,
  #shopify-section-{{ section.id }} .category-img-wrap svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  #shopify-section-{{ section.id }} .category-card:hover .category-img-wrap img {
    transform: scale(1.1);
  }

  #shopify-section-{{ section.id }} .category-name {
    text-align: center;
    font-weight: 500;
    font-size: 0.95rem;
    color: {{ section.settings.color_scheme.settings.text }};
    transition: color 0.2s ease;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .category-card:hover .category-name {
    color: {{ section.settings.color_scheme.settings.secondary_button_label }};
  }
{%- endstyle -%}

<section class="category-section">
  <div class="category-inner">

    {% comment %} ── Header ── {% endcomment %}
    {% if section.settings.title != blank or section.settings.subtitle != blank %}
      <div class="category-header js-reveal">
        {% if section.settings.title != blank %}
          <h2 class="category-title">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.subtitle != blank %}
          <p class="category-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% comment %} ── Grid ── {% endcomment %}
    <div class="category-grid">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          <a
            href="{{ block.settings.link }}"
            class="category-card js-reveal"
            style="transition-delay: {{ forloop.index0 | times: 100 }}ms;"
            {{ block.shopify_attributes }}
          >
            <div class="category-img-wrap">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 600
                  | image_tag:
                    widths: '200,300,400,600',
                    loading: 'lazy',
                    alt: block.settings.name
                }}
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag }}
              {% endif %}
            </div>
            {% if block.settings.name != blank %}
              <p class="category-name">{{ block.settings.name }}</p>
            {% endif %}
          </a>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        {% for i in (1..6) %}
          <a href="#" class="category-card js-reveal" style="transition-delay: {{ forloop.index0 | times: 100 }}ms;">
            <div class="category-img-wrap">
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag }}
            </div>
            <p class="category-name">Category {{ forloop.index }}</p>
          </a>
        {% endfor %}
      {% endif %}
    </div>

  </div>
</section>

<script>
(function() {
  {% comment %} Scroll reveal with IntersectionObserver {% endcomment %}
  const items = document.querySelectorAll('#shopify-section-{{ section.id }} .js-reveal');
  if (!items.length) return;

  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  items.forEach(function(el) { observer.observe(el); });
})();
</script>

{% schema %}
{
  "name": "Category Grid",
  "settings": [
    {
      "type": "header",
      "content": "Color & Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Border Radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_v_mobile",
      "label": "Padding Top/Bottom (Mobile)",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_v_desktop",
      "label": "Padding Top/Bottom (Desktop)",
      "min": 40,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 96
    },
    {
      "type": "header",
      "content": "Grid Columns"
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Columns (Tablet)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (Desktop)",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ],
      "default": "6"
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Shop by Category"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Explore our carefully curated collections designed for every space in your home"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Category Name",
          "default": "Living Room"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
