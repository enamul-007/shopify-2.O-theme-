{% comment %}
  ProductCard Snippet
  Usage: {% render 'product-card', product: product, index: forloop.index0 %}
{% endcomment %}

{% assign card_id = 'pc-' | append: product.id | append: '-' | append: index %}
{% assign delay_ms = index | times: 50 %}

{% assign rating = product.metafields.reviews.rating.value | default: '4.5' %}
{% assign review_count = product.metafields.reviews.rating_count.value | default: '0' %}

{% assign color_option_index = nil %}
{% for option in product.options %}
  {% assign option_down = option | downcase %}
  {% if option_down == 'color' or option_down == 'colour' %}
    {% assign color_option_index = forloop.index0 %}
  {% endif %}
{% endfor %}

{% assign all_colors = '' %}
{% if color_option_index != nil %}
  {% for variant in product.variants %}
    {% assign color_val = variant.options[color_option_index] %}
    {% unless all_colors contains color_val %}
      {% assign all_colors = all_colors | append: color_val | append: '|' %}
    {% endunless %}
  {% endfor %}
{% endif %}
{% assign color_list = all_colors | split: '|' | compact %}

<style>
  .pc-card {
    position: relative;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .pc-card.pc-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .pc-img-wrap {
    position: relative;
    aspect-ratio: 3 / 4;
    background-color: #f3f4f6;
    border-radius: 0.75rem;
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .pc-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .pc-card:hover .pc-img {
    transform: scale(1.05);
  }
  .pc-badges {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    z-index: 2;
  }
  .pc-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.4;
  }
  .pc-badge-new {
    background-color: #ffffff;
    color: #111827;
  }
  .pc-badge-sale {
    background-color: #ef4444;
    color: #ffffff;
  }
  .pc-actions {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    z-index: 2;
  }
  .pc-action-btn {
    width: 2.5rem;
    height: 2.5rem;
    background-color: #ffffff;
    border: none;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    cursor: pointer;
    opacity: 0;
    transform: translateX(10px);
    transition: opacity 0.2s ease, transform 0.2s ease, background-color 0.2s ease, color 0.2s ease;
    color: #111827;
  }
  .pc-action-btn:nth-child(2) {
    transition-delay: 0.05s;
  }
  .pc-card:hover .pc-action-btn {
    opacity: 1;
    transform: translateX(0);
  }
  .pc-action-btn:hover {
    background-color: #111827;
    color: #ffffff;
  }
  .pc-action-btn:disabled {
    cursor: not-allowed;
    opacity: 0.6;
  }
  .pc-action-btn svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .pc-action-btn.pc-wishlisted svg.heart-icon {
    fill: #ef4444;
    stroke: #ef4444;
  }
  .pc-quick-view-wrap {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 2;
  }
  .pc-card:hover .pc-quick-view-wrap {
    opacity: 1;
    transform: translateY(0);
  }
  .pc-quick-view-btn {
    display: block;
    width: 100%;
    padding: 0.625rem 1rem;
    background-color: #ffffff;
    color: #111827; 
    border: none;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
    box-sizing: border-box;
  }
  .pc-quick-view-btn:hover {
    background-color: #111827;
    color: #ffffff;
  }
  .pc-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .pc-rating {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.875rem;
  }
  .pc-rating svg {
    width: 14px;
    height: 14px;
    fill: #111827;
    stroke: #111827;
  }
  .pc-rating-score {
    font-weight: 500;
    color: #111827;
  }
  .pc-rating-count {
    color: #6b7280;
  }
  .pc-title {
    font-weight: 500;
    color: #111827;
    transition: color 0.2s ease;
    margin: 0;
    font-size: 1.50rem;
    line-height: 1.4;
    text-decoration: none;
    display: block;
  }
  .pc-card:hover .pc-title {
    color: #4b5563;
  }
  .pc-price-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .pc-price {
    font-size: 1.125rem;
    font-weight: 500;
    color: #111827;
  }
  .pc-compare-price {
    font-size: 0.875rem;
    color: #6b7280;
    text-decoration: line-through;
  }
  .pc-swatches {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding-top: 0.25rem;
    flex-wrap: wrap;
  }
  .pc-swatch {
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 9999px;
    border: 2px solid #e5e7eb;
    cursor: pointer;
    transition: border-color 0.2s ease;
    display: inline-block;
  }
  .pc-swatch:hover {
    border-color: #111827;
  }
  .pc-swatch-more {
    font-size: 0.75rem;
    color: #6b7280;
  }
  @keyframes pc-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>

<div
  id="{{ card_id }}"
  class="pc-card"
  style="transition-delay: {{ delay_ms }}ms;"
  data-product-card
>
  <a href="{{ product.url }}" style="display:block; text-decoration:none; color:inherit;">

    <div class="pc-img-wrap">

      {% if product.featured_image %}
        <img
          class="pc-img"
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.featured_image.alt | escape | default: product.title }}"
          width="600"
          loading="lazy"
        >
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'pc-img' }}
      {% endif %}

      <div class="pc-badges">
        {% if product.metafields.custom.is_new.value == true or product.tags contains 'new' %}
          <span class="pc-badge pc-badge-new">New</span>
        {% endif %}
        {% if product.compare_at_price > product.price %}
          {% assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
          <span class="pc-badge pc-badge-sale">-{{ discount_pct }}%</span>
        {% endif %}
      </div>

      <div class="pc-actions">
        <button
          class="pc-action-btn pc-wishlist-btn"
          aria-label="Add to wishlist"
          data-product-id="{{ product.id }}"
          onclick="event.preventDefault(); pcToggleWishlist(this, '{{ product.id }}')"
        >
          <svg class="heart-icon" viewBox="0 0 24 24">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </button>

        <button
          class="pc-action-btn pc-cart-btn"
          aria-label="Quick add to cart"
          data-variant-id="{{ product.selected_or_first_available_variant.id }}"
          onclick="event.preventDefault(); pcQuickAddToCart(this, '{{ product.selected_or_first_available_variant.id }}')"
        >
          <svg viewBox="0 0 24 24">
            <circle cx="9" cy="21" r="1"/>
            <circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
        </button>
      </div>

      <div class="pc-quick-view-wrap">
        <button
          class="pc-quick-view-btn"
          onclick="event.preventDefault(); pcOpenQuickView('{{ product.handle }}')"
        >
          Quick View
        </button>
      </div>

    </div>

    <div class="pc-info">

      <div class="pc-rating">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        <span class="pc-rating-score">{{ rating }}</span>
        <span class="pc-rating-count">({{ review_count }})</span>
      </div>

      <h3 class="pc-title">{{ product.title }}</h3>

      <div class="pc-price-row">
        <span class="pc-price">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="pc-compare-price">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>

      {% if color_list.size > 0 %}
        {% assign shown_colors = color_list | slice: 0, 4 %}
        {% assign extra_colors = color_list.size | minus: 4 %}
        <div class="pc-swatches">
          {% for color in shown_colors %}
            {% assign color_lower = color | downcase | strip %}
            {% assign swatch_color = '#cccccc' %}
            {% case color_lower %}
              {% when 'navy' %}{% assign swatch_color = '#1e3a8a' %}
              {% when 'gray', 'grey' %}{% assign swatch_color = '#6b7280' %}
              {% when 'emerald' %}{% assign swatch_color = '#059669' %}
              {% when 'blush' %}{% assign swatch_color = '#f9a8d4' %}
              {% when 'white' %}{% assign swatch_color = '#ffffff' %}
              {% when 'black' %}{% assign swatch_color = '#000000' %}
              {% when 'brass' %}{% assign swatch_color = '#d4a574' %}
              {% when 'terracotta' %}{% assign swatch_color = '#e07a5f' %}
              {% when 'natural' %}{% assign swatch_color = '#f5f5dc' %}
              {% when 'charcoal' %}{% assign swatch_color = '#36454f' %}
              {% when 'sage' %}{% assign swatch_color = '#87a878' %}
              {% when 'clear' %}{% assign swatch_color = '#f0f0f0' %}
              {% when 'smoke' %}{% assign swatch_color = '#738290' %}
              {% when 'amber' %}{% assign swatch_color = '#ffbf00' %}
              {% when 'ivory' %}{% assign swatch_color = '#fffff0' %}
              {% when 'red' %}{% assign swatch_color = '#ef4444' %}
              {% when 'blue' %}{% assign swatch_color = '#3b82f6' %}
              {% when 'green' %}{% assign swatch_color = '#22c55e' %}
              {% when 'yellow' %}{% assign swatch_color = '#eab308' %}
              {% when 'pink' %}{% assign swatch_color = '#ec4899' %}
              {% when 'purple' %}{% assign swatch_color = '#a855f7' %}
              {% when 'orange' %}{% assign swatch_color = '#f97316' %}
              {% when 'brown' %}{% assign swatch_color = '#92400e' %}
              {% when 'beige' %}{% assign swatch_color = '#f5f0e8' %}
              {% when 'gold' %}{% assign swatch_color = '#d4af37' %}
              {% when 'silver' %}{% assign swatch_color = '#c0c0c0' %}
            {% endcase %}
            <span
              class="pc-swatch"
              style="background-color: {{ swatch_color }};"
              title="{{ color }}"
              aria-label="{{ color }}"
            ></span>
          {% endfor %}
          {% if extra_colors > 0 %}
            <span class="pc-swatch-more">+{{ extra_colors }}</span>
          {% endif %}
        </div>
      {% endif %}

    </div>
  </a>
</div>

{% unless pc_scripts_loaded %}
  {% assign pc_scripts_loaded = true %}
<script>
(function () {

  /* ── Intersection Observer ── */
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('pc-visible');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  function initCards() {
    document.querySelectorAll('[data-product-card]').forEach(function (el) {
      io.observe(el);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCards);
  } else {
    initCards();
  }

  /* ── Wishlist toggle ── */
  window.pcToggleWishlist = function (btn, productId) {
    btn.classList.toggle('pc-wishlisted');
  };

  /* ── Quick add to cart ── */
  window.pcQuickAddToCart = function (btn, variantId) {
    var id = parseInt(variantId, 10);
    if (!id) {
      console.error('[PC] Invalid variant ID:', variantId);
      return;
    }

    btn.disabled = true;
    var originalHTML = btn.innerHTML;

    btn.innerHTML = '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="animation:pc-spin 0.6s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ id: id, quantity: 1 })
    })
    .then(function (r) {
      if (!r.ok) throw new Error('Cart error: ' + r.status);
      return r.json();
    })
    .then(function () {
      btn.innerHTML = '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';

      /* Cart count update */
      fetch('/cart.js')
        .then(function (r) { return r.json(); })
        .then(function (cart) {
          document.querySelectorAll('#cartCounter, .cart-count, [data-cart-count]').forEach(function (el) {
            el.textContent = cart.item_count > 0 ? '(' + cart.item_count + ')' : '';
          });
          document.dispatchEvent(new CustomEvent('cart:refresh', { detail: cart }));
        });

      setTimeout(function () {
        btn.innerHTML = originalHTML;
        btn.disabled = false;
      }, 1500);
    })
    .catch(function (e) {
      console.error('[PC] Cart error:', e);
      btn.innerHTML = originalHTML;
      btn.disabled = false;
    });
  };

  /* ── Quick View ── */
  window.pcOpenQuickView = function (handle) {
    document.dispatchEvent(new CustomEvent('quickview:open', { detail: { handle: handle } }));
  };

})();
</script>
{% endunless %}