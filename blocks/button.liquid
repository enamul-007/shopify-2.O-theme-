{% comment %}
  Block: button.liquid
  Fix: block object must be explicitly passed to the snippet
  because {% render %} runs in an isolated scope.
{% endcomment %}

{% render 'button', link: block.settings.link, block: block %}

{% schema %}
{
  "name": "Button",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "select",
      "id": "style_class",
      "label": "Button Style",
      "options": [
        { "value": "button",           "label": "Primary" },
        { "value": "button-secondary", "label": "Secondary" },
        { "value": "link",             "label": "Link" }
      ],
      "default": "button"
    },
    {
      "type": "header",
      "content": "Size"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width (Desktop)",
      "options": [
        { "value": "fit-content", "label": "Fit Content" },
        { "value": "custom",      "label": "Custom" }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom Width (Desktop)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "Width (Mobile)",
      "options": [
        { "value": "fit-content", "label": "Fit Content" },
        { "value": "custom",      "label": "Custom" }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "Custom Width (Mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == 'custom' }}"
    }
  ],
  "presets": [
    {
      "name": "Button",
      "settings": {
        "link": "shopify://collections/all"
      }
    }
  ]
}
{% endschema %}
