{% comment %}
  blocks/product-title.liquid
  Theme block — product title, vendor name, and star rating placeholder.
{% endcomment %}

<div class="pt-title-wrap" {{ block.shopify_attributes }} style="margin-bottom:1rem;">

  {%- if block.settings.show_vendor -%}
  <p style="color:var(--pt-mid,#6b7280); font-size:0.875rem; margin:0 0 0.4rem; text-transform:uppercase; letter-spacing:0.05em;">
    {{ product.vendor }}
  </p>
  {%- endif -%}

  <h1
    class="pt-title"
    style="font-size:{{ block.settings.title_size }}px; margin:0 0 0.5rem; line-height:1.2; font-weight:700;"
  >
    {{ product.title }}
  </h1>

  {%- if block.settings.show_rating -%}
  <div class="pt-rating" style="display:flex; align-items:center; gap:0.5rem; margin-top:0.5rem;">
    <div class="pt-stars" style="display:flex; gap:2px; color:var(--pt-accent,#b45309);">
      {%- for i in (1..5) -%}
      <svg viewBox="0 0 16 16" fill="currentColor" style="width:16px;height:16px;">
        <path d="M8 1l1.8 3.6L14 5.4l-3 2.9.7 4.1L8 10.4l-3.7 2 .7-4.1-3-2.9 4.2-.8z"/>
      </svg>
      {%- endfor -%}
    </div>
    <span style="color:var(--pt-mid,#6b7280); font-size:0.875rem;">
      {{ product.metafields.reviews.rating_count | default: '0' }}
      {{ block.settings.reviews_label | default: 'reviews' }}
    </span>
  </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Product Title",
  "settings": [
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor",      "default": false },
    { "type": "range",    "id": "title_size",  "label": "Title size (px)",  "min": 20, "max": 60, "step": 2, "default": 36 },
    { "type": "checkbox", "id": "show_rating", "label": "Show star rating", "default": true },
    { "type": "text",     "id": "reviews_label","label": "Reviews label",   "default": "reviews" }
  ],
  "presets": [
    { "name": "Product Title" }
  ]
}
{% endschema %}
