{%- style -%}
  {% comment %} ── Card Base ── {% endcomment %}
  .editorial-card[data-block-id="{{ block.id }}"] {
    position: relative;
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    display: block;
    text-decoration: none;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .editorial-card[data-block-id="{{ block.id }}"].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  {% comment %} ── Size variants — height: 100% to fill grid row ── {% endcomment %}
  .editorial-card[data-block-id="{{ block.id }}"] {
    height: 100%;
  }
  .editorial-card[data-block-id="{{ block.id }}"].editorial-card--large { min-height: 480px; }
  .editorial-card[data-block-id="{{ block.id }}"].editorial-card--small { min-height: 260px; }

  @media (min-width: 768px) {
    .editorial-card[data-block-id="{{ block.id }}"].editorial-card--large { min-height: 540px; }
    .editorial-card[data-block-id="{{ block.id }}"].editorial-card--small { min-height: 290px; }
  }

  {% comment %} ── Card Image ── {% endcomment %}
  .editorial-card[data-block-id="{{ block.id }}"] .editorial-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s ease, opacity 0.6s ease;
  }
  .editorial-card[data-block-id="{{ block.id }}"]:hover .editorial-card__img {
    transform: scale(1.05);
  }

  {% comment %} ── Second image (hover reveal) ── {% endcomment %}
  .editorial-card[data-block-id="{{ block.id }}"] .editorial-card__img2 {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .editorial-card[data-block-id="{{ block.id }}"]:hover .editorial-card__img2 {
    opacity: 1;
  }
  .editorial-card[data-block-id="{{ block.id }}"]:hover .editorial-card__img {
    opacity: 0;
  }

  {% comment %} ── Overlay gradient ── {% endcomment %}
  .editorial-card[data-block-id="{{ block.id }}"] .editorial-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.75) 0%,
      rgba(0,0,0,0.2) 50%,
      transparent 100%
    );
  }

  {% comment %} ── Card Body — nested blocks render here ── {% endcomment %}
  .editorial-card[data-block-id="{{ block.id }}"] .editorial-card__body {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.75rem;
    gap: 0.5rem;
  }

  {% comment %} ── Button overrides inside card — white/ghost on dark image ── {% endcomment %}
  .editorial-card[data-block-id="{{ block.id }}"] .editorial-card__body .button,
  .editorial-card[data-block-id="{{ block.id }}"] .editorial-card__body [class*="button--"] {
    background-color: #ffffff;
    border-color: #ffffff;
    color: #111111;
  }
  .editorial-card[data-block-id="{{ block.id }}"] .editorial-card__body .button:hover,
  .editorial-card[data-block-id="{{ block.id }}"] .editorial-card__body [class*="button--"]:hover {
    background-color: rgba(255,255,255,0.85);
    border-color: rgba(255,255,255,0.85);
    color: #111111;
    box-shadow: 0 4px 16px rgba(0,0,0,0.25);
  }

  .editorial-card[data-block-id="{{ block.id }}"] .editorial-card__body .button-secondary {
    background-color: transparent;
    border-color: rgba(255,255,255,0.7);
    color: #ffffff;
  }
  .editorial-card[data-block-id="{{ block.id }}"] .editorial-card__body .button-secondary:hover {
    background-color: rgba(255,255,255,0.15);
    border-color: #ffffff;
    color: #ffffff;
  }

  .editorial-card[data-block-id="{{ block.id }}"] .editorial-card__body .link {
    color: #ffffff;
    text-decoration-color: rgba(255,255,255,0.5);
  }
  .editorial-card[data-block-id="{{ block.id }}"] .editorial-card__body .link:hover {
    color: #ffffff;
    text-decoration-color: #ffffff;
  }

  {% comment %} ── Button wrapper div — remove any default block spacing ── {% endcomment %}
  .editorial-card[data-block-id="{{ block.id }}"] .editorial-card__body > div {
    margin: 0;
    padding: 0;
  }
{%- endstyle -%}

{%- assign card_size = block.settings.card_size | default: 'small' -%}

<a
  href="{{ block.settings.link }}"
  class="editorial-card editorial-card--{{ card_size }} js-ed-reveal"
  data-block-id="{{ block.id }}"
  {{ block.shopify_attributes }}
>

  {% comment %} Primary image {% endcomment %}
  {% if block.settings.image != blank %}
    {{
      block.settings.image
      | image_url: width: 1400
      | image_tag:
        class: 'editorial-card__img',
        widths: '600,900,1200,1400',
        loading: 'lazy',
        alt: block.settings.image.alt
    }}
  {% else %}
    {{ 'lifestyle-1' | placeholder_svg_tag: 'editorial-card__img' }}
  {% endif %}

  {% comment %} Hover image {% endcomment %}
  {% if block.settings.image2 != blank %}
    {{
      block.settings.image2
      | image_url: width: 1400
      | image_tag:
        class: 'editorial-card__img2',
        widths: '600,900,1200,1400',
        loading: 'lazy',
        alt: block.settings.image2.alt
    }}
  {% endif %}

  <div class="editorial-card__overlay"></div>

  {% comment %} Badge, heading, subheading, button — সব nested theme blocks এখানে render হবে {% endcomment %}
  <div class="editorial-card__body">
    {% content_for 'blocks' %}
  </div>

</a>

<script>
(function() {
  var card = document.querySelector('.editorial-card[data-block-id="{{ block.id }}"]');
  if (!card) return;
  if (!('IntersectionObserver' in window)) {
    card.classList.add('is-visible');
    return;
  }
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        obs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });
  obs.observe(card);
})();
</script>

{% schema %}
{
  "name": "Editorial Card",
  "blocks": [{ "type": "@theme" }, { "type": "@app" }],
  "settings": [
    {
      "type": "header",
      "content": "Card Size"
    },
    {
      "type": "select",
      "id": "card_size",
      "label": "Card Size",
      "options": [
        { "value": "large", "label": "Large (tall)" },
        { "value": "small", "label": "Small (short)" }
      ],
      "default": "small",
      "info": "First card in the grid spans full width — set it to Large for best results."
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Primary Image"
    },
    {
      "type": "image_picker",
      "id": "image2",
      "label": "Hover Image (2nd)"
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Card Link"
    }
  ],
  "presets": [
    {
      "name": "Editorial Card",
      "settings": {
        "card_size": "small"
      }
    },
    {
      "name": "Editorial Card — Large",
      "settings": {
        "card_size": "large"
      }
    }
  ]
}
{% endschema %}
