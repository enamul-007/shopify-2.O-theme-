{% comment %}
  ============================================================
  blocks/testimonial-author.liquid
  — Author name, company and role block inside testimonial-card.
  ============================================================
{% endcomment %}

<div class="ts-author" {{ block.shopify_attributes }}>
  {%- if block.settings.name != blank -%}
    <p class="ts-name">{{ block.settings.name }}</p>
  {%- endif -%}
  {%- if block.settings.role != blank -%}
    <p class="ts-role">{{ block.settings.role }}</p>
  {%- endif -%}
  {%- if block.settings.company != blank -%}
    <p class="ts-company">{{ block.settings.company }}</p>
  {%- endif -%}
</div>

{% stylesheet %}
  .ts-author {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 2px;
  }
  .ts-name {
    font-size: 15px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
    line-height: 1.3;
  }
  .ts-role {
    font-size: 12px;
    color: #aaa;
    margin: 0;
    line-height: 1.3;
  }
  .ts-company {
    font-size: 11px;
    color: #bbb;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin: 0;
    line-height: 1.3;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Author Info",
  "settings": [
    {
      "type": "text",
      "id": "name",
      "label": "Customer name",
      "default": "Sarah Rahman"
    },
    {
      "type": "text",
      "id": "company",
      "label": "Company name",
      "default": "NextGen SaaS"
    },
    {
      "type": "text",
      "id": "role",
      "label": "Role / title",
      "default": "Marketing Director"
    }
  ],
  "presets": [
    { "name": "Author Info" }
  ]
}
{% endschema %}