{% comment %}
  blocks/product-accordion.liquid
  Theme block — a single collapsible accordion row.
  Add as many of these blocks as you like inside product-details;
  each one becomes its own expandable panel in the theme editor.
{% endcomment %}

{%- if block.settings.heading != blank -%}
<div
  class="pt-accordion"
  {{ block.shopify_attributes }}
  style="margin-bottom:0.25rem;"
>
  <button
    type="button"
    class="pt-accordion-trigger"
    aria-expanded="{{ block.settings.open_by_default }}"
    aria-controls="pt-acc-body-{{ block.id }}"
    style="
      background:none;
      border:none;
      border-top:1px solid var(--pt-border,#e5e7eb);
      width:100%;
      text-align:left;
      padding:0.875rem 0;
      cursor:pointer;
      display:flex;
      justify-content:space-between;
      align-items:center;
      font-weight:600;
      font-size:{{ block.settings.heading_size }}px;
      color:var(--pt-text,#111);
    "
  >
    <span>{{ block.settings.heading }}</span>
    <svg
      class="pt-accordion-icon"
      viewBox="0 0 16 16"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      style="
        width:16px; height:16px; flex-shrink:0;
        transition:transform 0.3s ease;
        {% if block.settings.open_by_default %}transform:rotate(180deg);{% endif %}
      "
    >
      <polyline points="4 6 8 10 12 6"/>
    </svg>
  </button>

  <div
    class="pt-accordion-body"
    id="pt-acc-body-{{ block.id }}"
    style="
      {% unless block.settings.open_by_default %}display:none;{% endunless %}
      padding-bottom:0.875rem;
    "
  >
    <div
      class="rte"
      style="
        font-size:{{ block.settings.content_size }}px;
        line-height:1.7;
        color:var(--pt-mid,#6b7280);
      "
    >
      {{ block.settings.content }}
    </div>
  </div>
</div>
{%- endif -%}

{% javascript %}
document.querySelectorAll('.pt-accordion-trigger').forEach(function(trigger) {
  // Respect open_by_default on page load — already handled via inline style.
  trigger.addEventListener('click', function() {
    var bodyId   = trigger.getAttribute('aria-controls');
    var body     = document.getElementById(bodyId);
    var icon     = trigger.querySelector('.pt-accordion-icon');
    var expanded = trigger.getAttribute('aria-expanded') === 'true';

    trigger.setAttribute('aria-expanded', String(!expanded));
    body.style.display = expanded ? 'none' : 'block';
    if (icon) icon.style.transform = expanded ? '' : 'rotate(180deg)';
  });
});
{% endjavascript %}

{% schema %}
{
  "name": "Accordion",
  "settings": [
    { "type": "text",     "id": "heading",          "label": "Heading",               "default": "Product details"  },
    { "type": "richtext", "id": "content",           "label": "Content"                                              },
    { "type": "range",    "id": "heading_size",      "label": "Heading font size (px)","min": 13, "max": 20, "step": 1, "default": 15 },
    { "type": "range",    "id": "content_size",      "label": "Content font size (px)","min": 12, "max": 18, "step": 1, "default": 14 },
    { "type": "checkbox", "id": "open_by_default",   "label": "Open by default",       "default": false }
  ],
  "presets": [
    {
      "name": "Accordion",
      "settings": {
        "heading": "Product details",
        "content": "<p>Share details about this product here.</p>"
      }
    },
    {
      "name": "Shipping info",
      "settings": {
        "heading": "Shipping & returns",
        "content": "<p>Free standard shipping on orders over $150. Returns accepted within 30 days.</p>"
      }
    },
    {
      "name": "Size guide",
      "settings": {
        "heading": "Size guide",
        "content": "<p>See our size chart to find your perfect fit.</p>"
      }
    }
  ]
}
{% endschema %}
