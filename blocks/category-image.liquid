{%- liquid
  assign img_width  = block.settings.image_width
  assign img_align  = block.settings.image_alignment
  assign border_r   = block.settings.border_radius
  assign aspect     = block.settings.aspect_ratio
-%}

{%- style -%}
  #block-{{ block.id }} .cat-img-outer {
    display: flex;
    justify-content: {{ img_align }};
    width: 100%;
  }

  #block-{{ block.id }} .cat-img-wrap {
    width: {{ img_width }}%;
    aspect-ratio: {{ aspect }};
    border-radius: {{ border_r }}px;
    overflow: hidden;
    position: relative;
  }

  #block-{{ block.id }} .cat-img-wrap img,
  #block-{{ block.id }} .cat-img-wrap svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  #block-{{ block.id }} .cat-img-wrap:hover img {
    transform: scale(1.06);
  }
{%- endstyle -%}

<div id="block-{{ block.id }}" class="cat-img-block" {{ block.shopify_attributes }}>
  <div class="cat-img-outer">
    <div class="cat-img-wrap">
      {%- if block.settings.image != blank -%}
        {{
          block.settings.image
          | image_url: width: 800
          | image_tag:
            widths: '200,400,600,800',
            loading: 'lazy',
            alt: block.settings.image_alt
        }}
      {%- else -%}
        {{ 'collection-1' | placeholder_svg_tag }}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Category Image",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Alt Text",
      "info": "Describe the image for screen readers and SEO",
      "default": "Category image"
    },
    {
      "type": "header",
      "content": "Size & Shape"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image Width",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect Ratio",
      "options": [
        { "value": "1 / 1",   "label": "Square (1:1)" },
        { "value": "4 / 3",   "label": "Landscape (4:3)" },
        { "value": "3 / 4",   "label": "Portrait (3:4)" },
        { "value": "16 / 9",  "label": "Wide (16:9)" },
        { "value": "2 / 3",   "label": "Tall (2:3)" }
      ],
      "default": "1 / 1"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Alignment"
    },
    {
      "type": "select",
      "id": "image_alignment",
      "label": "Horizontal Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center",     "label": "Center" },
        { "value": "flex-end",   "label": "Right" }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "Category Image"
    }
  ]
}
{% endschema %}
