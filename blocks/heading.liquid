{%- liquid
  assign tag = block.settings.heading_tag

  # Typography preset overrides
  assign preset = block.settings.type_preset
  assign font_family = block.settings.font
  assign font_size = block.settings.font_size
  assign font_weight = block.settings.font_weight
  assign line_height = block.settings.line_height
  assign letter_spacing = block.settings.letter_spacing
  assign text_case = block.settings.text_case
  assign text_wrap = block.settings.text_wrap

  # Width
  assign width = block.settings.width
  assign max_width = block.settings.max_width

  # Alignment
  assign alignment = block.settings.alignment

  # Appearance
  assign color = block.settings.color
  assign bg_color = block.settings.background_color
  assign has_bg = block.settings.background
  assign radius = block.settings.corner_radius

  # Padding
  assign pt = block.settings.padding_top
  assign pb = block.settings.padding_bottom
  assign pl = block.settings.padding_left
  assign pr = block.settings.padding_right
-%}

{%- style -%}
  #block-{{ block.id }} {
    /* ── Width ── */
    {%- if width == 'fill' -%}
      width: 100%;
    {%- elsif width == 'fit' -%}
      width: fit-content;
    {%- elsif width == 'custom' -%}
      width: {{ block.settings.custom_width }}%;
    {%- endif -%}

    /* ── Max Width ── */
    {%- unless max_width == 'none' -%}
      max-width: {{ max_width }};
    {%- endunless -%}

    /* ── Alignment ── */
    text-align: {{ alignment }};
    {%- if alignment == 'center' -%}
      margin-inline: auto;
    {%- elsif alignment == 'right' -%}
      margin-inline-start: auto;
    {%- endif -%}

    /* ── Typography Preset ── */
    {%- if preset == 'h1' -%}
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.02em;
    {%- elsif preset == 'h2' -%}
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: -0.01em;
    {%- elsif preset == 'h3' -%}
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      font-weight: 600;
      line-height: 1.2;
    {%- elsif preset == 'h4' -%}
      font-size: clamp(1.25rem, 2.5vw, 1.75rem);
      font-weight: 600;
      line-height: 1.25;
    {%- elsif preset == 'h5' -%}
      font-size: clamp(1rem, 2vw, 1.375rem);
      font-weight: 600;
      line-height: 1.3;
    {%- elsif preset == 'h6' -%}
      font-size: clamp(0.875rem, 1.5vw, 1.125rem);
      font-weight: 600;
      line-height: 1.35;
      letter-spacing: 0.02em;
    {%- elsif preset == 'p' -%}
      font-size: 1rem;
      font-weight: 400;
      line-height: 1.6;
    {%- endif -%}

    /* ── Custom Font (only if preset == custom) ── */
    {%- if preset == 'custom' -%}
      {%- if font_family == 'heading' -%}
        font-family: var(--font-heading-family, serif);
      {%- elsif font_family == 'subheading' -%}
        font-family: var(--font-heading-family, sans-serif);
        font-style: italic;
      {%- elsif font_family == 'body' -%}
        font-family: var(--font-body-family, sans-serif);
      {%- elsif font_family == 'accent' -%}
        font-family: var(--font-accent-family, monospace);
      {%- endif -%}
      font-size: {{ font_size }}px;
      font-weight: {{ font_weight }};
      line-height: {{ line_height | divided_by: 10.0 }};
      letter-spacing: {{ letter_spacing | divided_by: 100.0 }}em;
    {%- endif -%}

    /* ── Case & Wrap ── */
    {%- unless text_case == 'none' -%}
      text-transform: {{ text_case }};
    {%- endunless -%}
    text-wrap: {{ text_wrap }};

    /* ── Color ── */
    {%- if color != blank -%}
      color: {{ color }};
    {%- endif -%}

    /* ── Background ── */
    {%- if has_bg -%}
      background-color: {{ bg_color }};
    {%- endif -%}

    /* ── Corner Radius ── */
    {%- if radius > 0 -%}
      border-radius: {{ radius }}px;
    {%- endif -%}

    /* ── Padding ── */
    padding: {{ pt }}px {{ pr }}px {{ pb }}px {{ pl }}px;

    /* ── Display ── */
    display: block;
    box-sizing: border-box;
  }
{%- endstyle -%}

<{{ tag }}
  id="block-{{ block.id }}"
  {{ block.shopify_attributes }}
>
  {{ block.settings.text }}
</{{ tag }}>

{% schema %}
{
  "name": "Heading",
  "settings": [

    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Timeless Design for Modern Living</p>"
    },

    {
      "type": "header",
      "content": "── Layout ──────────────────────────"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "options": [
        { "value": "fit",    "label": "Fit Content" },
        { "value": "fill",   "label": "Fill (100%)" },
        { "value": "custom", "label": "Custom (%)" }
      ],
      "default": "fill"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom Width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "max_width",
      "label": "Max Width",
      "options": [
        { "value": "none",   "label": "None" },
        { "value": "320px",  "label": "Narrow (320px)" },
        { "value": "480px",  "label": "Small (480px)" },
        { "value": "640px",  "label": "Medium (640px)" },
        { "value": "768px",  "label": "Wide (768px)" },
        { "value": "100%",   "label": "Full" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left",    "label": "← Left" },
        { "value": "center",  "label": "↔ Center" },
        { "value": "right",   "label": "→ Right" }
      ],
      "default": "left"
    },

    {
      "type": "header",
      "content": "── Typography ──────────────────────"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "HTML Tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "p",  "label": "P (Paragraph)" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "type_preset",
      "label": "Typography Preset",
      "options": [
        { "value": "h1",     "label": "H1 — Display" },
        { "value": "h2",     "label": "H2 — Heading" },
        { "value": "h3",     "label": "H3 — Subheading" },
        { "value": "h4",     "label": "H4 — Section Title" },
        { "value": "h5",     "label": "H5 — Small Heading" },
        { "value": "h6",     "label": "H6 — Label" },
        { "value": "p",      "label": "P — Body Text" },
        { "value": "custom", "label": "✏️ Custom" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "font",
      "label": "Font Family",
      "info": "Uses your theme font variables",
      "options": [
        { "value": "heading",    "label": "Heading Font" },
        { "value": "subheading", "label": "Subheading (italic)" },
        { "value": "body",       "label": "Body Font" },
        { "value": "accent",     "label": "Accent Font" }
      ],
      "default": "heading",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font Size",
      "min": 10,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 48,
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "300", "label": "Light (300)" },
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi Bold (600)" },
        { "value": "700", "label": "Bold (700)" },
        { "value": "800", "label": "Extra Bold (800)" },
        { "value": "900", "label": "Black (900)" }
      ],
      "default": "700",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line Height",
      "min": 8,
      "max": 30,
      "step": 1,
      "default": 12,
      "info": "Value ÷ 10 = actual (e.g. 12 → 1.2)",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter Spacing",
      "min": -10,
      "max": 30,
      "step": 1,
      "default": 0,
      "info": "Value ÷ 100 = em (e.g. -2 → -0.02em)",
      "visible_if": "{{ block.settings.type_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "text_case",
      "label": "Case",
      "options": [
        { "value": "none",       "label": "Default" },
        { "value": "uppercase",  "label": "UPPERCASE" },
        { "value": "lowercase",  "label": "lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "text_wrap",
      "label": "Text Wrap",
      "options": [
        { "value": "wrap",    "label": "Wrap (default)" },
        { "value": "balance", "label": "Balance" },
        { "value": "pretty",  "label": "Pretty" },
        { "value": "nowrap",  "label": "No Wrap" }
      ],
      "default": "pretty"
    },

    {
      "type": "header",
      "content": "── Appearance ──────────────────────"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "background",
      "label": "Enable Background Color",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F5F5F5",
      "visible_if": "{{ block.settings.background }}"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner Radius",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 0
    },

    {
      "type": "header",
      "content": "── Padding ─────────────────────────"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding Left",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding Right",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    }

  ],
  "presets": [
    {
      "name": "Heading",
      "settings": {
        "text": "<p>Timeless Design for Modern Living</p>",
        "heading_tag": "h2",
        "type_preset": "h2",
        "alignment": "left"
      }
    },
    {
      "name": "Display Heading",
      "settings": {
        "text": "<p>Bold. Beautiful. Unforgettable.</p>",
        "heading_tag": "h1",
        "type_preset": "h1",
        "alignment": "center",
        "text_wrap": "balance"
      }
    },
    {
      "name": "Section Label",
      "settings": {
        "text": "<p>Our Collection</p>",
        "heading_tag": "h6",
        "type_preset": "h6",
        "text_case": "uppercase",
        "alignment": "left"
      }
    },
    {
      "name": "Custom Heading",
      "settings": {
        "text": "<p>Your Custom Heading</p>",
        "heading_tag": "h2",
        "type_preset": "custom",
        "font": "heading",
        "font_size": 48,
        "font_weight": "700",
        "line_height": 12,
        "letter_spacing": -2,
        "alignment": "left"
      }
    }
  ]
}
{% endschema %}
