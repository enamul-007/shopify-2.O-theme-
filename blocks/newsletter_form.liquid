<div class="newsletter-form-wrapper" {{ block.shopify_attributes }} style="max-width: 500px; margin: 25px auto 0;">
  {%- form 'customer', class: 'newsletter-form-inner' -%}
    <input type="hidden" name="contact[tags]" value="newsletter">
    
    {%- if form.posted_successfully? -%}
      <p style="color: #2e7d32; font-weight: 600;">{{ block.settings.success_msg }}</p>
    {%- else -%}
      <div class="input-group-premium" style="display: flex; flex-wrap: wrap; gap: 10px; position: relative;">
        <div class="input-field-wrapper" style="position: relative; flex: 1 1 300px;">
          <input
            type="email"
            name="contact[email]"
            id="Email-{{ block.id }}"
            class="premium-input"
            value="{{ form.email }}"
            placeholder=" "
            required
            style="width: 100%; height: 60px; padding: 20px 20px 10px; border: 1px solid rgba(0,0,0,0.1); border-radius: {{ block.settings.radius }}px; outline: none;"
          >
          <label class="premium-label" for="Email-{{ block.id }}" style="position: absolute; left: 20px; top: 50%; transform: translateY(-50%); transition: all 0.2s ease; pointer-events: none; color: #888;">
            {{ block.settings.placeholder }}
          </label>
        </div>
        <button type="submit" style="height: 60px; padding: 0 35px; border: none; border-radius: {{ block.settings.radius }}px; background: #000; color: #fff; font-weight: 600; cursor: pointer;">
          {{ block.settings.button_label }}
        </button>
      </div>
    {%- endif -%}

    {%- if form.errors -%}
      <p style="color: red; font-size: 13px;">{{ form.errors.messages.email }}</p>
    {%- endif -%}
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Newsletter Form",
  "settings": [
    { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "Your email" },
    { "type": "text", "id": "button_label", "label": "Button", "default": "Subscribe" },
    { "type": "range", "id": "radius", "min": 0, "max": 40, "step": 2, "default": 8, "label": "Radius" },
    { "type": "text", "id": "success_msg", "label": "Success Message", "default": "Welcome!" }
  ]
}
{% endschema %}