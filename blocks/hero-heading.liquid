        { "value": "center",  "label": "↔ Center" },
        { "value": "right",   "label": "→ Right" }
      ],
      "default": "center"
    },
    
    {
      "type": "header",
      "content": "── Typography ──────────────────────"
    },
    {
      "type": "select",
      "id": "type_preset",
      "label": "Typography Preset",
      "options": [
        { "value": "h1",     "label": "H1 — Display" },
        { "value": "h2",     "label": "H2 — Heading" },
        { "value": "h3",     "label": "H3 — Subheading" },
        { "value": "h4",     "label": "H4 — Section Title" },
        { "value": "h5",     "label": "H5 — Small Heading" },
        { "value": "h6",     "label": "H6 — Label" },
        { "value": "p",      "label": "P — Body Text" },
        { "value": "custom", "label": "✏️ Custom" }
      ],
      "default": "h3"
    },
    {
      "type": "select",
      "id": "font",
      "label": "Font Family",
