{%- liquid
  # Marquee configuration
  assign marquee_direction = block.settings.direction
  assign marquee_speed = block.settings.speed
  assign marquee_gap = block.settings.gap
  assign marquee_pause = block.settings.pause_on_hover
  assign marquee_duplicate = block.settings.duplicate_content
  
  # Typography preset overrides
  assign preset = block.settings.type_preset
  assign font_family = block.settings.font
  assign font_size = block.settings.font_size
  assign font_weight = block.settings.font_weight
  assign line_height = block.settings.line_height
  assign letter_spacing = block.settings.letter_spacing
  assign text_case = block.settings.text_case
  assign text_wrap = block.settings.text_wrap
  
  # Width
  assign width = block.settings.width
  assign max_width = block.settings.max_width
  
  # Alignment
  assign alignment = block.settings.alignment
  
  # Appearance
  assign color = block.settings.color
  assign bg_color = block.settings.background_color
  assign has_bg = block.settings.background
  assign radius = block.settings.corner_radius
  
  # Spacing
  assign pt = block.settings.padding_top
  assign pb = block.settings.padding_bottom
  assign pl = block.settings.padding_left
  assign pr = block.settings.padding_right
  
  # Icon settings
  assign show_icon = block.settings.show_icon
  assign icon_position = block.settings.icon_position
  assign icon = block.settings.icon
  assign icon_color = block.settings.icon_color
  assign icon_size = block.settings.icon_size
-%}

{%- style -%}
  #block-{{ block.id }} {
    /* ── Width ── */
    {%- if width == 'fill' -%}
      width: 100%;
    {%- elsif width == 'fit' -%}
      width: fit-content;
    {%- elsif width == 'custom' -%}
      width: {{ block.settings.custom_width }}%;
    {%- endif -%}
    
    /* ── Max Width ── */
    {%- unless max_width == 'none' -%}
      max-width: {{ max_width }};
    {%- endunless -%}
    
    /* ── Alignment ── */
    text-align: {{ alignment }};
    {%- if alignment == 'center' -%}
      margin-inline: auto;
    {%- elsif alignment == 'right' -%}
      margin-inline-start: auto;
    {%- endif -%}
    
    /* ── Typography ── */
    {%- if preset == 'h1' -%}
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.02em;
    {%- elsif preset == 'h2' -%}
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: -0.01em;
    {%- elsif preset == 'h3' -%}
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      font-weight: 600;
      line-height: 1.2;
    {%- elsif preset == 'h4' -%}
      font-size: clamp(1.25rem, 2.5vw, 1.75rem);
      font-weight: 600;
      line-height: 1.25;
    {%- elsif preset == 'h5' -%}
      font-size: clamp(1rem, 2vw, 1.375rem);
      font-weight: 600;
      line-height: 1.3;
    {%- elsif preset == 'h6' -%}
      font-size: clamp(0.875rem, 1.5vw, 1.125rem);
      font-weight: 600;
      line-height: 1.35;
      letter-spacing: 0.02em;
    {%- elsif preset == 'p' -%}
      font-size: 1rem;
      font-weight: 400;
      line-height: 1.6;
    {%- endif -%}
    
    /* ── Custom Font ── */
    {%- if preset == 'custom' -%}
      {%- if font_family == 'heading' -%}
        font-family: var(--font-heading-family, serif);
      {%- elsif font_family == 'subheading' -%}
        font-family: var(--font-heading-family, sans-serif);
        font-style: italic;
      {%- elsif font_family == 'body' -%}
        font-family: var(--font-body-family, sans-serif);
      {%- elsif font_family == 'accent' -%}
        font-family: var(--font-accent-family, monospace);
      {%- endif -%}
      font-size: {{ font_size }}px;
      font-weight: {{ font_weight }};
      line-height: {{ line_height | divided_by: 10.0 }};
      letter-spacing: {{ letter_spacing | divided_by: 100.0 }}em;
    {%- endif -%}
    
    /* ── Case & Wrap ── */
    {%- unless text_case == 'none' -%}
      text-transform: {{ text_case }};
    {%- endunless -%}
    text-wrap: {{ text_wrap }};
    
    /* ── Color ── */
    {%- if color != blank -%}
      color: {{ color }};
    {%- endif -%}
    
    /* ── Icon styles ── */
    {%- if show_icon -%}
      --marquee-icon-color: {{ icon_color | default: color }};
      --marquee-icon-size: {{ icon_size }}px;
    {%- endif -%}
    
    /* ── Background ── */
    {%- if has_bg -%}
      background-color: {{ bg_color }};
    {%- endif -%}
    
    /* ── Corner Radius ── */
    {%- if radius > 0 -%}
      border-radius: {{ radius }}px;
    {%- endif -%}
    
    /* ── Padding ── */
    padding: {{ pt }}px {{ pr }}px {{ pb }}px {{ pl }}px;
    
    /* ── Display ── */
    display: block;
    box-sizing: border-box;
  }
  
  /* ── Marquee Container Styles ── */
  #block-{{ block.id }} .marquee-container {
    overflow: hidden;
    width: 100%;
    position: relative;
  }
  
  #block-{{ block.id }} .marquee-track {
    display: flex;
    gap: {{ marquee_gap }}px;
    width: fit-content;
    animation: marquee-scroll-{{ block.id }} {{ marquee_speed }}s linear infinite;
    {% if marquee_direction == 'right' %}
      animation-direction: reverse;
    {% endif %}
    {% if marquee_pause %}
      animation-play-state: running;
    {% endif %}
  }
  
  #block-{{ block.id }} .marquee-container:hover .marquee-track {
    {% if marquee_pause %}
      animation-play-state: paused;
    {% endif %}
  }
  
  #block-{{ block.id }} .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: {{ marquee_gap }}px;
    flex-shrink: 0;
    white-space: nowrap;
  }
  
  #block-{{ block.id }} .marquee-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--marquee-icon-color);
    font-size: var(--marquee-icon-size);
    line-height: 1;
  }
  
  /* Icon position styles */
  #block-{{ block.id }} .marquee-icon--left {
    order: -1;
  }
  
  #block-{{ block.id }} .marquee-icon--right {
    order: 1;
  }
  
  /* Animation keyframes */
  @keyframes marquee-scroll-{{ block.id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  
  /* Responsive font adjustments */
  @media (max-width: 768px) {
    #block-{{ block.id }} .marquee-item {
      white-space: normal;
      word-break: keep-all;
    }
  }
{%- endstyle -%}

<div class="marquee-container" {{ block.shopify_attributes }}>
  <div class="marquee-track">
    {%- assign max_loops = 2 -%}
    {%- if marquee_duplicate == false -%}
      {%- assign max_loops = 1 -%}
    {%- endif -%}
    
    {%- for i in (1..max_loops) -%}
      {%- assign items = block.settings.marquee_items | split: ',' -%}
      {%- for item in items -%}
        {%- assign clean_item = item | strip -%}
        {%- if clean_item != blank -%}
          <div class="marquee-item">
            {%- if show_icon and icon_position == 'left' -%}
              <span class="marquee-icon marquee-icon--left">
                {%- if icon contains '<svg' or icon contains 'fa-' -%}
                  {{ icon }}
                {%- else -%}
                  {{ icon | default: '✦' }}
                {%- endif -%}
              </span>
            {%- endif -%}
            
            <span>{{ clean_item }}</span>
            
            {%- if show_icon and icon_position == 'right' -%}
              <span class="marquee-icon marquee-icon--right">
                {%- if icon contains '<svg' or icon contains 'fa-' -%}
                  {{ icon }}
                {%- else -%}
                  {{ icon | default: '✦' }}
                {%- endif -%}
              </span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    {
      "type": "header",
      "content": "── Content ──────────────────────────"
    },
    {
      "type": "textarea",
      "id": "marquee_items",
      "label": "Marquee Items",
      "default": "✨ Free Shipping, 🔥 30% Off, ⭐ Limited Edition, 🚀 Fast Delivery",
      "info": "Separate items with commas. Example: Item 1, Item 2, Item 3"
    },
    
    {
      "type": "header",
      "content": "── Animation ────────────────────────"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        { "value": "left", "label": "← Left to Right" },
        { "value": "right", "label": "→ Right to Left" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Animation Speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "sec",
      "default": 20,
      "info": "Lower = faster, Higher = slower"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap Between Items",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on Hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "duplicate_content",
      "label": "Duplicate Content for Seamless Loop",
      "default": true,
      "info": "Creates a seamless infinite scroll effect"
    },
    
    {
      "type": "header",
      "content": "── Icon Settings ────────────────────"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show Icon",
      "default": true
    },
    {
      "type": "select",
      "id": "icon_position",
      "label": "Icon Position",
      "options": [
        { "value": "left", "label": "Left of Text" },
        { "value": "right", "label": "Right of Text" }
      ],
      "default": "left",
      "visible_if": "{{ block.settings.show_icon }}"
    },
    {
      "type": "text",
      "id": "icon",
      "label": "Icon",
      "default": "✦",
      "info": "Use emojis (✨), symbols (★), or HTML/SVG. Example: ✨ or <svg>...</svg>",
      "visible_if": "{{ block.settings.show_icon }}"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#111111",
      "visible_if": "{{ block.settings.show_icon }}"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Size",
      "min": 12,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 20,
      "visible_if": "{{ block.settings.show_icon }}"
    },
    
    {
      "type": "header",
      "content": "── Layout ──────────────────────────"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "options": [
        { "value": "fit",    "label": "Fit Content" },
        { "value": "fill",   "label": "Fill (100%)" },
        { "value": "custom", "label": "Custom (%)" }
      ],
      "default": "fill"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom Width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "max_width",
      "label": "Max Width",
      "options": [
        { "value": "none",   "label": "None" },
        { "value": "320px",  "label": "Narrow (320px)" },
        { "value": "480px",  "label": "Small (480px)" },
        { "value": "640px",  "label": "Medium (640px)" },
        { "value": "768px",  "label": "Wide (768px)" },
        { "value": "1024px", "label": "Extra Wide (1024px)" },
        { "value": "100%",   "label": "Full" }
      ],
      "default": "none"
    },
    {
